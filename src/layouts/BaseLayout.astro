---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string;
  type?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = "Chef de projet & Expert en transformation digitale — 15 ans d'expérience en télécom, management et formation.",
  image = "/images/profile.jpg",
  keywords = "chef de projet, transformation digitale, management, formation, télécom, portfolio",
  type = "website",
  jsonLd,
} = Astro.props;

// JSON-LD Person schema (always present)
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Gérald Paméole",
  "url": "https://geraldpameole.fr",
  "jobTitle": "Chef de Projet & Expert Transformation Digitale",
  "worksFor": { "@type": "Organization", "name": "KEOS TELECOM" },
  "sameAs": [
    "https://www.linkedin.com/in/gerald-pameole/",
    "https://github.com/GeraldPameole"
  ]
};

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://geraldpameole.fr');
const pageTitle = `${title} | Gérald Paméole`;
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Gérald Paméole" />
  <meta name="keywords" content={keywords} />
  <meta name="theme-color" content="#050816" />

  <meta property="og:title"       content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type"        content={type} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:image"       content={new URL(image, Astro.site || 'https://geraldpameole.fr')} />
  <meta property="og:site_name"   content="Gérald Paméole" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={new URL(image, Astro.site || 'https://geraldpameole.fr')} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" type="application/rss+xml" title="Gérald Paméole — Blog" href="/rss.xml" />
  <meta name="generator" content={Astro.generator} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd ?? personSchema)} />

  <slot name="head" />
  <ViewTransitions fallback="swap" />
</head>
<body>
  <Header />
  <main id="main" class="pt-20">
    <slot />
  </main>
  <BackToTop />
  <Footer />

  <!-- Scroll reveal observer -->
  <script is:inline>
    if (typeof IntersectionObserver !== 'undefined') {
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }),
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      const observe = () => document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
      document.addEventListener('DOMContentLoaded', observe);
      document.addEventListener('astro:page-load', observe);
    }
  </script>

  <slot name="scripts" />
</body>
</html>
