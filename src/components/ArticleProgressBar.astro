---
---

<div id="read-progress" aria-hidden="true">
  <div id="read-fill"></div>
  <span id="read-pct">0%</span>
</div>

<style>
#read-progress {
  position: fixed;
  right: 1.25rem;
  top: 50%;
  transform: translateY(-50%);
  z-index: 200;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .75rem;
  pointer-events: none;
}

#read-progress::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 4px;
  transform: translateX(-50%);
  background: rgba(255,255,255,0.07);
  border-radius: 2px;
}

#read-fill {
  position: absolute;
  left: 50%;
  top: 0;
  width: 4px;
  transform: translateX(-50%);
  height: 0%;
  background: linear-gradient(to bottom, var(--cyan, #00cffd), var(--violet, #915EFF));
  border-radius: 2px;
  transition: height .1s linear;
  box-shadow: 0 0 8px rgba(0,207,253,0.4);
}

#read-pct {
  position: absolute;
  bottom: -2rem;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-mono, monospace);
  font-size: .68rem;
  font-weight: 700;
  color: var(--cyan, #00cffd);
  background: rgba(5,8,22,0.85);
  border: 1px solid rgba(0,207,253,0.25);
  border-radius: 20px;
  padding: .2rem .55rem;
  min-width: 2.4rem;
  text-align: center;
}

/* height of the track = 240px */
#read-progress { height: 240px; }

@media(max-width:1024px) { #read-progress { right: .5rem; height: 180px; } }
@media(max-width:768px)  { #read-progress { display: none; } }
</style>

<script>
// Singleton stocké sur window pour survivre aux View Transitions tout en
// restant idempotent (1 seul couple de listeners scroll/resize au total).
// Avant : chaque astro:page-load attachait un NOUVEAU couple de listeners
// scroll/resize, chacun lisant scrollHeight => reflow synchrone par event
// multiplie par N navigations. Cause directe du scroll cadence/saccade.
(function () {
  if ((window as any).__readProgressBound) return;
  (window as any).__readProgressBound = true;

  let fill: HTMLElement | null = null;
  let pct: HTMLElement | null = null;
  let ticking = false;
  let cachedTotal = 0;

  function refreshTotal() {
    // Lit scrollHeight UNE seule fois (forced reflow). Re-mesure sur resize
    // ou sur DOM update (cf. astro:page-load).
    cachedTotal = document.documentElement.scrollHeight - window.innerHeight;
  }

  function update() {
    if (!fill || !pct) return;
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const progress = cachedTotal > 0
        ? Math.round((window.scrollY / cachedTotal) * 100)
        : 0;
      fill!.style.height = progress + '%';
      pct!.textContent   = progress + '%';
      ticking = false;
    });
  }

  function rebind() {
    fill = document.getElementById('read-fill');
    pct  = document.getElementById('read-pct');
    if (!fill || !pct) return;
    refreshTotal();
    update();
  }

  // 1 SEUL listener scroll global, attache une fois pour toutes
  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', () => { refreshTotal(); update(); }, { passive: true });

  // Re-bind sur chaque navigation client-side (les DOM IDs changent)
  document.addEventListener('astro:page-load', rebind);
  if (document.readyState !== 'loading') rebind();
  else document.addEventListener('DOMContentLoaded', rebind);
})();
</script>
