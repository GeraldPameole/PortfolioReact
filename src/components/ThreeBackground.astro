---
---
<canvas id="three-bg" aria-hidden="true" style="position:absolute;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"></canvas>
<div id="three-bg-label" aria-hidden="true" style="position:absolute;bottom:1.5rem;right:1.5rem;z-index:1;max-width:340px;font-family:'JetBrains Mono',monospace;color:#b4c5ff;opacity:0;transition:opacity .6s ease;pointer-events:none;text-shadow:0 0 8px rgba(180,197,255,.35);text-align:right;">
  <div data-cn-name style="font-size:.95rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;line-height:1.2;margin-bottom:.35rem;color:#fff;"></div>
  <div data-cn-fact style="font-size:.72rem;line-height:1.5;letter-spacing:.04em;color:#9fb3df;"></div>
</div>

<script type="module">
import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.162.0/build/three.module.min.js';

const canvas = document.getElementById('three-bg');
if (!canvas) throw new Error('no canvas');

// ── Renderer ──────────────────────────────────────────────────────────────────
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setClearColor(0x000000, 0);
renderer.setSize(canvas.offsetWidth, canvas.offsetHeight);

// ── Scene + Camera ────────────────────────────────────────────────────────────
const scene  = new THREE.Scene();
// Fog exponentiel pour simuler la profondeur de l'espace (lumière qui se perd
// avec la distance) — couleur bleu nuit très sombre, densité douce
scene.fog = new THREE.FogExp2(0x050816, 0.011);

const camera = new THREE.PerspectiveCamera(60, canvas.offsetWidth / canvas.offsetHeight, 0.1, 1000);
// Démarre TRÈS proche du centre — l'intro zoomera dehors pour passer de
// l'échelle humaine à l'échelle cosmique (effet "Powers of Ten")
camera.position.set(0, 0, 4);

// État de l'intro zoom cosmique
const INTRO_DURATION = 4.0;   // secondes
const CAMERA_START_Z = 4;     // proche (échelle humaine)
const CAMERA_END_Z   = 28;    // final (échelle cosmique)
let introProgress = 0;

// ── Modes (styles aléatoires) ─────────────────────────────────────────────────
// Chaque mode garde le côté futuriste. La forme terrestre (icosaèdres) reste
// toujours visible, indépendante du mode.
const MODES = [
  {
    name: 'constellation',
    palette: [0x915EFF, 0x00CFFD, 0xffffff],  // violet, cyan, blanc
    connectDist: 7,
    lineOpacity: 0.22,
    nodeOpacityBase: 0.55,
    nodeOpacityAmp:  0.35,
    driftScale: 1.0,
    trackForce: 0.0028,
    trackRadius: 6,
    swirl: 0,
  },
  {
    name: 'vortex',
    palette: [0xff5599, 0x915EFF, 0x00CFFD],  // rose/violet/cyan
    connectDist: 5.5,
    lineOpacity: 0.18,
    nodeOpacityBase: 0.6,
    nodeOpacityAmp:  0.3,
    driftScale: 0.6,
    trackForce: 0.0045,
    trackRadius: 7,
    swirl: 0.0009,
  },
  {
    name: 'neural',
    palette: [0x00ffaa, 0x60a5fa, 0xa78bfa],  // vert/bleu/violet
    connectDist: 8.5,
    lineOpacity: 0.32,
    nodeOpacityBase: 0.5,
    nodeOpacityAmp:  0.45,
    driftScale: 0.4,
    trackForce: 0.0035,
    trackRadius: 8,
    swirl: 0,
  },
  {
    name: 'galaxy',
    palette: [0xfbbf24, 0xfb923c, 0x915EFF],  // ambre/orange/violet
    connectDist: 6,
    lineOpacity: 0.16,
    nodeOpacityBase: 0.55,
    nodeOpacityAmp:  0.35,
    driftScale: 0.8,
    trackForce: 0.0022,
    trackRadius: 5.5,
    swirl: 0.0014,
  },
];

let modeIdx = 0;
let nextModeIdx = 0;
let modeBlend = 1;                 // 0 → mode courant, 1 → mode cible (atteint)
const MODE_DURATION = 14;          // secondes par mode
const MODE_BLEND_TIME = 2.2;       // secondes de transition
let lastModeSwitch = 0;

function pickNextMode() {
  let n;
  do { n = Math.floor(Math.random() * MODES.length); } while (n === modeIdx && MODES.length > 1);
  nextModeIdx = n;
  modeBlend = 0;
}

function lerp(a, b, t) { return a + (b - a) * t; }

function currentMode() { return MODES[modeIdx]; }
function targetMode()  { return MODES[nextModeIdx]; }

function blendedNum(key) {
  return lerp(currentMode()[key], targetMode()[key], modeBlend);
}

function blendedColor(i) {
  const c1 = new THREE.Color(currentMode().palette[i % currentMode().palette.length]);
  const c2 = new THREE.Color(targetMode().palette[i % targetMode().palette.length]);
  return c1.lerp(c2, modeBlend);
}

// ── Nodes ─────────────────────────────────────────────────────────────────────
const NODE_COUNT = 90;
const SPREAD = 18;
const nodes  = [];
const nodeGeo = new THREE.SphereGeometry(0.12, 8, 8);

for (let i = 0; i < NODE_COUNT; i++) {
  const paletteIdx = Math.floor(Math.random() * 3);
  const mat = new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.8 });
  const mesh = new THREE.Mesh(nodeGeo, mat);
  mesh.position.set(
    (Math.random() - 0.5) * SPREAD * 2,
    (Math.random() - 0.5) * SPREAD,
    (Math.random() - 0.5) * SPREAD * 1.5
  );
  mesh.userData = {
    paletteIdx,
    vx: (Math.random() - 0.5) * 0.012,
    vy: (Math.random() - 0.5) * 0.008,
    vz: (Math.random() - 0.5) * 0.006,
    phase: Math.random() * Math.PI * 2,
  };
  scene.add(mesh);
  nodes.push(mesh);
}

// ── Lines (connections) ───────────────────────────────────────────────────────
const lineMat = new THREE.LineBasicMaterial({
  vertexColors: true,
  transparent: true,
  opacity: 0.22,
  blending: THREE.AdditiveBlending,
});
const lineSegments = [];

function buildLines() {
  lineSegments.forEach(l => { scene.remove(l); l.geometry.dispose(); });
  lineSegments.length = 0;

  const positions = [];
  const colors    = [];
  const palA = blendedColor(0);
  const palB = blendedColor(1);
  const connectDist = blendedNum('connectDist');

  for (let i = 0; i < NODE_COUNT; i++) {
    for (let j = i + 1; j < NODE_COUNT; j++) {
      const d = nodes[i].position.distanceTo(nodes[j].position);
      if (d < connectDist) {
        const col = palA.clone().lerp(palB, Math.random());
        positions.push(...nodes[i].position.toArray(), ...nodes[j].position.toArray());
        colors.push(col.r, col.g, col.b, col.r, col.g, col.b);
      }
    }
  }

  if (positions.length === 0) return;
  const geo = new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
  geo.setAttribute('color',    new THREE.Float32BufferAttribute(colors, 3));
  lineMat.opacity = blendedNum('lineOpacity');
  const line = new THREE.LineSegments(geo, lineMat);
  scene.add(line);
  lineSegments.push(line);
}

buildLines();

// ── Forme terrestre : icosaèdres centraux (préservés, indépendants du mode) ──
const icoGeo = new THREE.IcosahedronGeometry(4.5, 1);
const icoMat = new THREE.MeshBasicMaterial({ color: 0x915EFF, wireframe: true, transparent: true, opacity: 0.08 });
const ico = new THREE.Mesh(icoGeo, icoMat);
scene.add(ico);

const ico2Geo = new THREE.IcosahedronGeometry(7, 1);
const ico2Mat = new THREE.MeshBasicMaterial({ color: 0x00CFFD, wireframe: true, transparent: true, opacity: 0.04 });
const ico2 = new THREE.Mesh(ico2Geo, ico2Mat);
ico2.rotation.z = 0.5;
scene.add(ico2);

// ── Fond étoilé profond (champ stellaire dense, multi-couleurs) ───────────────
// 3000 étoiles distribuées sur une sphère, palette riche évoquant les vraies
// teintes du ciel profond (blanc, bleu, jaune, orange, rougeâtre).
const STARFIELD_COUNT  = 3000;
const STARFIELD_RADIUS = 90;
const starPositions = new Float32Array(STARFIELD_COUNT * 3);
const starColors    = new Float32Array(STARFIELD_COUNT * 3);
const starColorPalette = [
  new THREE.Color(0xffffff),  // blanc (40%)
  new THREE.Color(0xffffff),
  new THREE.Color(0xc8d6ff),  // bleuté
  new THREE.Color(0xbfd3ff),
  new THREE.Color(0xffe9c0),  // jaunâtre
  new THREE.Color(0xffd0b5),  // orangé
  new THREE.Color(0xfcb6c4),  // rosé
  new THREE.Color(0xe9d5ff),  // lavande pâle
];
for (let i = 0; i < STARFIELD_COUNT; i++) {
  const u = Math.random();
  const v = Math.random();
  const theta = 2 * Math.PI * u;
  const phi   = Math.acos(2 * v - 1);
  const r     = STARFIELD_RADIUS * (0.65 + Math.random() * 0.7);
  starPositions[i * 3]     = r * Math.sin(phi) * Math.cos(theta);
  starPositions[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
  starPositions[i * 3 + 2] = r * Math.cos(phi);
  const col = starColorPalette[Math.floor(Math.random() * starColorPalette.length)];
  const intensity = 0.35 + Math.pow(Math.random(), 1.5) * 0.65;
  starColors[i * 3]     = col.r * intensity;
  starColors[i * 3 + 1] = col.g * intensity;
  starColors[i * 3 + 2] = col.b * intensity;
}
const starGeo = new THREE.BufferGeometry();
starGeo.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
starGeo.setAttribute('color',    new THREE.BufferAttribute(starColors, 3));
const starMat = new THREE.PointsMaterial({
  size: 0.55,
  vertexColors: true,
  transparent: true,
  opacity: 0.95,
  sizeAttenuation: true,
  blending: THREE.AdditiveBlending,
  depthWrite: false,
});
const starfield = new THREE.Points(starGeo, starMat);
scene.add(starfield);

// ── Étoiles brillantes (premier plan stellaire) ───────────────────────────────
// ~80 étoiles plus grosses avec halo doux — donne le contraste de l'image.
const BRIGHT_COUNT = 80;
const brightPositions = new Float32Array(BRIGHT_COUNT * 3);
const brightColors    = new Float32Array(BRIGHT_COUNT * 3);
const brightPhases    = new Float32Array(BRIGHT_COUNT);
const brightPalette = [
  new THREE.Color(0xffffff),
  new THREE.Color(0xdce8ff),
  new THREE.Color(0xfff2c8),
];
for (let i = 0; i < BRIGHT_COUNT; i++) {
  const u = Math.random();
  const v = Math.random();
  const theta = 2 * Math.PI * u;
  const phi   = Math.acos(2 * v - 1);
  const r     = 75 + Math.random() * 25;
  brightPositions[i * 3]     = r * Math.sin(phi) * Math.cos(theta);
  brightPositions[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
  brightPositions[i * 3 + 2] = r * Math.cos(phi);
  const col = brightPalette[Math.floor(Math.random() * brightPalette.length)];
  brightColors[i * 3]     = col.r;
  brightColors[i * 3 + 1] = col.g;
  brightColors[i * 3 + 2] = col.b;
  brightPhases[i] = Math.random() * Math.PI * 2;
}
const brightGeo = new THREE.BufferGeometry();
brightGeo.setAttribute('position', new THREE.BufferAttribute(brightPositions, 3));
brightGeo.setAttribute('color',    new THREE.BufferAttribute(brightColors, 3));
const brightMat = new THREE.PointsMaterial({
  size: 2.6,
  vertexColors: true,
  transparent: true,
  opacity: 0.95,
  sizeAttenuation: true,
  blending: THREE.AdditiveBlending,
  depthWrite: false,
});
const brightStars = new THREE.Points(brightGeo, brightMat);
scene.add(brightStars);

// ── Nuages galactiques animés (nébulosité interstellaire) ─────────────────────
// 6 nuages diffus aux couleurs de l'univers (violet, magenta, lavande, crème,
// bleu profond, pourpre). Chaque nuage est un ensemble de gros points très
// translucides, distribués en blob 3D gaussien, qui dérive lentement.
const NEBULA_COLORS = [
  { core: 0x9333ea, halo: 0xc4b5fd },   // violet → lavande
  { core: 0xd946ef, halo: 0xfbcfe8 },   // magenta → rose pâle
  { core: 0x6d28d9, halo: 0x818cf8 },   // pourpre → indigo
  { core: 0xfed7aa, halo: 0xfef3c7 },   // crème / orange doux (centre galactique)
  { core: 0x3b1d68, halo: 0x7c3aed },   // bleu nuit profond → violet
  { core: 0xec4899, halo: 0xa78bfa },   // rose magenta → violet pâle
];
const NEBULA_POINTS_PER_CLOUD = 280;
const nebulaClouds = [];

function createNebulaCloud(colorPair, center, radius) {
  const positions = new Float32Array(NEBULA_POINTS_PER_CLOUD * 3);
  const colors    = new Float32Array(NEBULA_POINTS_PER_CLOUD * 3);
  const coreCol = new THREE.Color(colorPair.core);
  const haloCol = new THREE.Color(colorPair.halo);
  for (let i = 0; i < NEBULA_POINTS_PER_CLOUD; i++) {
    const dist = (Math.random() + Math.random() + Math.random()) / 3;
    const theta = Math.random() * Math.PI * 2;
    const phi   = Math.acos(2 * Math.random() - 1);
    const r = dist * radius;
    positions[i * 3]     = r * Math.sin(phi) * Math.cos(theta);
    positions[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta) * 0.65;
    positions[i * 3 + 2] = r * Math.cos(phi) * 0.45;
    const col = coreCol.clone().lerp(haloCol, dist);
    const intensity = 0.4 + (1 - dist) * 0.7;
    colors[i * 3]     = col.r * intensity;
    colors[i * 3 + 1] = col.g * intensity;
    colors[i * 3 + 2] = col.b * intensity;
  }
  const geo = new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  geo.setAttribute('color',    new THREE.BufferAttribute(colors, 3));
  const mat = new THREE.PointsMaterial({
    size: 4.5,
    vertexColors: true,
    transparent: true,
    opacity: 0.22,
    sizeAttenuation: true,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
  });
  const points = new THREE.Points(geo, mat);
  points.position.set(center.x, center.y, center.z);
  return {
    mesh: points,
    mat,
    basePosition: { ...center },
    // Profondeur cyclique : le nuage se rapproche puis s'éloigne dans la
    // profondeur (effet de "fog reveal" — disparaît dans le lointain, revient)
    zNear: center.z,                  // position de présence (visible)
    zFar:  center.z - 40,             // position lointaine (invisible dans le fog)
    cycleDuration: 30 + Math.random() * 35,  // 30-65s par nuage
    cyclePhase: Math.random(),        // déphasage initial 0..1
    driftPhase: Math.random() * Math.PI * 2,
    driftSpeed: 0.04 + Math.random() * 0.06,
    rotSpeed:   (Math.random() - 0.5) * 0.012,
    twinkleBase:  0.16 + Math.random() * 0.12,
    twinkleAmp:   0.06 + Math.random() * 0.06,
    twinklePhase: Math.random() * Math.PI * 2,
  };
}

// 6 nuages aux positions variées en profondeur (z entre -45 et -75)
const NEBULA_LAYOUT = [
  { x: -35, y:  15, z: -55 },
  { x:  30, y:  20, z: -65 },
  { x: -20, y: -22, z: -50 },
  { x:  25, y: -18, z: -60 },
  { x:   0, y:  10, z: -75 },
  { x:  -5, y: -30, z: -45 },
];
for (let i = 0; i < NEBULA_LAYOUT.length; i++) {
  const cloud = createNebulaCloud(
    NEBULA_COLORS[i % NEBULA_COLORS.length],
    NEBULA_LAYOUT[i],
    18 + Math.random() * 8,
  );
  scene.add(cloud.mesh);
  nebulaClouds.push(cloud);
}

// ── Planètes orbitales (rotation continue) ────────────────────────────────────
// 4 planètes en orbite autour du centre, profondeurs variées, vitesses
// différentes (loi de Kepler simplifiée : plus loin = plus lent).
const planets = [];

function makePlanet({ radius, color, orbitR, orbitSpeed, orbitTilt, zNear, zFar, cycleDuration, hasRing, ringColor, isEarth }) {
  // La sphère elle-même
  const sphereMat = new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0 });
  const sphere = new THREE.Mesh(new THREE.SphereGeometry(radius, 32, 32), sphereMat);
  // Halo atmosphérique léger
  const haloMat = new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0, blending: THREE.AdditiveBlending });
  const halo = new THREE.Mesh(new THREE.SphereGeometry(radius * 1.35, 24, 24), haloMat);
  sphere.add(halo);

  // Track all materials with their peak opacity (pour fade in/out)
  const tracked = [
    { m: sphereMat, peak: 0.92 },
    { m: haloMat,   peak: 0.18 },
  ];

  // Anneaux optionnels (style Saturne)
  if (hasRing) {
    const ringMat = new THREE.MeshBasicMaterial({
      color: ringColor,
      side: THREE.DoubleSide,
      transparent: true,
      opacity: 0,
    });
    const ring = new THREE.Mesh(new THREE.RingGeometry(radius * 1.5, radius * 2.4, 64), ringMat);
    ring.rotation.x = Math.PI / 2 - 0.4;
    sphere.add(ring);
    tracked.push({ m: ringMat, peak: 0.55 });
  }

  return {
    mesh: sphere,
    tracked,
    orbitR,
    orbitSpeed,
    orbitTilt,
    zNear,
    zFar,
    cycleDuration,
    cyclePhase: Math.random(),                    // 0..1, déphasage initial
    phase: Math.random() * Math.PI * 2,
    spinSpeed: 0.4 + Math.random() * 0.6,
    isEarth: !!isEarth,
  };
}

// Profondeur variable + cycle apparition/disparition propre à chaque planète :
// zNear = la planète est "présente" (proche, visible)
// zFar  = la planète est "lointaine" (loin, invisible)
// cycleDuration = durée d'un cycle complet (apparition → disparition → retour)
const PLANET_CONFIG = [
  // Terre (avec sa Lune) — cycle moyen, bleu-vert
  { radius: 0.7,  color: 0x4f8df5, orbitR: 11, orbitSpeed: 0.065, orbitTilt: 0.04,
    zNear: -9, zFar: -45, cycleDuration: 32, hasRing: false, isEarth: true },
  // Géante orange type Jupiter — moyenne, cycle moyen
  { radius: 1.0,  color: 0xfb923c, orbitR: 15, orbitSpeed: 0.055, orbitTilt: 0.12,
    zNear: -10, zFar: -55, cycleDuration: 38, hasRing: false },
  // Géante bleue type Neptune — VERY loin la plupart du temps
  { radius: 0.75, color: 0x4f7ff5, orbitR: 22, orbitSpeed: 0.035, orbitTilt: -0.18,
    zNear: -22, zFar: -75, cycleDuration: 55, hasRing: false },
  // Saturne avec anneaux — cycle long, profondeur moyenne
  { radius: 0.85, color: 0xfde68a, orbitR: 19, orbitSpeed: 0.045, orbitTilt: 0.25,
    zNear: -14, zFar: -60, cycleDuration: 48, hasRing: true, ringColor: 0xd6c894 },
  // Mars rocheuse — cycle court, proche
  { radius: 0.5,  color: 0xc05a3b, orbitR: 7,  orbitSpeed: 0.09, orbitTilt: -0.08,
    zNear: -8, zFar: -42, cycleDuration: 28, hasRing: false },
];

PLANET_CONFIG.forEach(cfg => {
  const p = makePlanet(cfg);
  scene.add(p.mesh);
  planets.push(p);
});

// ── Lune (satellite de la Terre) ──────────────────────────────────────────────
// La Lune suit la Terre et orbite autour d'elle (rotation rapide).
const moonGeo = new THREE.SphereGeometry(0.18, 24, 24);
const moonMat = new THREE.MeshBasicMaterial({ color: 0xcbd5e1, transparent: true, opacity: 0 });
const moon = new THREE.Mesh(moonGeo, moonMat);
const moonHaloMat = new THREE.MeshBasicMaterial({ color: 0xe2e8f0, transparent: true, opacity: 0, blending: THREE.AdditiveBlending });
const moonHalo = new THREE.Mesh(new THREE.SphereGeometry(0.28, 18, 18), moonHaloMat);
moon.add(moonHalo);
scene.add(moon);
const MOON_ORBIT_R     = 1.6;       // distance Lune ↔ Terre
const MOON_ORBIT_SPEED = 1.4;       // ~4-5 secondes par tour

// ── Orbites visualisées (anneaux fins en arrière-plan) ────────────────────────
// 3 anneaux discrets pour matérialiser les trajectoires : Terre, Jupiter, Saturne
// + l'orbite de la Lune autour de la Terre. Couleur très atténuée, opacité basse.
function makeOrbitRing(radius, color, opacity, yScale = 0.35) {
  const segments = 128;
  const positions = new Float32Array((segments + 1) * 3);
  for (let i = 0; i <= segments; i++) {
    const a = (i / segments) * Math.PI * 2;
    positions[i * 3]     = Math.cos(a) * radius;
    positions[i * 3 + 1] = Math.sin(a) * radius * yScale;
    positions[i * 3 + 2] = 0;
  }
  const geo = new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  const mat = new THREE.LineBasicMaterial({
    color, transparent: true, opacity, blending: THREE.AdditiveBlending,
  });
  return { line: new THREE.LineLoop(geo, mat), mat, peak: opacity };
}

// Orbites planétaires : Terre/Jupiter/Saturne (placées à un Z proche du
// "milieu" de leur cycle de profondeur pour rester visibles)
const earthOrbitVis   = makeOrbitRing(11, 0x4f8df5, 0.20);
const jupiterOrbitVis = makeOrbitRing(15, 0xfb923c, 0.14);
const saturnOrbitVis  = makeOrbitRing(19, 0xfde68a, 0.14);
earthOrbitVis.line.position.z   = -22;
jupiterOrbitVis.line.position.z = -28;
saturnOrbitVis.line.position.z  = -32;
scene.add(earthOrbitVis.line, jupiterOrbitVis.line, saturnOrbitVis.line);

// Orbite de la Lune autour de la Terre (rappel visuel — suivra la Terre)
const moonOrbitVis = makeOrbitRing(MOON_ORBIT_R, 0xcbd5e1, 0.25, 0.4);
scene.add(moonOrbitVis.line);

// ── Resize ────────────────────────────────────────────────────────────────────
let rebuildTimer;
function onResize() {
  const w = canvas.offsetWidth, h = canvas.offsetHeight;
  renderer.setSize(w, h);
  camera.aspect = w / h;
  camera.updateProjectionMatrix();
  clearTimeout(rebuildTimer);
  rebuildTimer = setTimeout(buildLines, 400);
}
window.addEventListener('resize', onResize, { passive: true });

// ── Constellations en arrière-plan ────────────────────────────────────────────
// Représentations stylisées des grandes constellations, projetées sur un plan
// lointain (z = -28). Une seule visible à la fois, fade in/out toutes les 10s.
// Coordonnées dans un repère local [-1, 1] remappées à l'échelle scène.
const BG_Z          = -28;
const CONST_SCALE_X = 22;
const CONST_SCALE_Y = 11;

const CONSTELLATIONS = [
  // ── Les 7 grandes/complexes (déjà présentes) ────────────────────────────────
  {
    name: 'Hydre',
    fact: "La plus grande constellation du ciel (1303°²) · 68 étoiles à l'œil nu · s'étend sur 100° du ciel · visible de janvier à juin",
    stars: [
      [-0.92,  0.55], [-0.82, 0.65], [-0.78, 0.48], [-0.7, 0.6],
