    stars: [
      [0.0, 0.6], [-0.18, 0.42], [0.18, 0.42], [-0.22, 0.05], [0.22, 0.1], [0.0, -0.3],
    ],
    edges: [[0,1],[0,2],[1,2],[1,3],[2,4],[3,5],[4,5],[3,4]],
    specials: [{ index: 0, name: 'Véga', size: 0.55 }],
  },
];

const constMatBase = { star: 0xb4c5ff, starBright: 0xffd96a, line: 0x6da3ff };

CONSTELLATIONS.forEach(c => {
  const g = new THREE.Group();
  g.position.set(0, 0, BG_Z);

  c.starsRef = [];
  c.stars.forEach((p, i) => {
    const special = c.specials.find(s => s.index === i);
    const r = special ? special.size : 0.14;
    const mat = new THREE.MeshBasicMaterial({
      color: special ? constMatBase.starBright : constMatBase.star,
      transparent: true,
      opacity: 0,
    });
    const sphere = new THREE.Mesh(new THREE.SphereGeometry(r, 12, 12), mat);
    sphere.position.set(p[0] * CONST_SCALE_X, p[1] * CONST_SCALE_Y, 0);
    g.add(sphere);
    c.starsRef.push(sphere);

    // Halo subtil pour les étoiles brillantes notables
    if (special) {
      const haloMat = new THREE.MeshBasicMaterial({
        color: constMatBase.starBright,
        transparent: true,
        opacity: 0,
      });
      const halo = new THREE.Mesh(new THREE.SphereGeometry(r * 2.4, 14, 14), haloMat);
      halo.position.copy(sphere.position);
      halo.userData.isHalo = true;
      g.add(halo);
      c.starsRef.push(halo);
    }
  });

  // Lines
  const positions = [];
  c.edges.forEach(([a, b]) => {
    const pa = c.stars[a], pb = c.stars[b];
    positions.push(pa[0] * CONST_SCALE_X, pa[1] * CONST_SCALE_Y, 0);
    positions.push(pb[0] * CONST_SCALE_X, pb[1] * CONST_SCALE_Y, 0);
  });
  const lineGeo = new THREE.BufferGeometry();
  lineGeo.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
  const lineMatC = new THREE.LineBasicMaterial({
    color: constMatBase.line,
    transparent: true,
    opacity: 0,
    blending: THREE.AdditiveBlending,
  });
  c.linesRef = new THREE.LineSegments(lineGeo, lineMatC);
  g.add(c.linesRef);

  scene.add(g);
  c.group = g;
});

// État du cycle constellation
let constIdx     = 0;
let constTimer   = 0;
const CONST_INTERVAL = 6;         // 6s par constellation (cycle complet)
const CONST_FADE     = 0.9;       // 0.9s fade in / out
const CONST_PEAK_OP  = 0.55;      // opacité max (en arrière-plan)
const CONST_ZOOM_AMP = 1.0;       // amplitude du zoom des traits sur les côtés (très prononcé)

const labelEl     = document.getElementById('three-bg-label');
const labelNameEl = labelEl?.querySelector('[data-cn-name]');
const labelFactEl = labelEl?.querySelector('[data-cn-fact]');

function setConstellationAlpha(c, alpha) {
  c.starsRef.forEach(s => {
    const isHalo = s.userData && s.userData.isHalo;
    s.material.opacity = alpha * (isHalo ? 0.4 : 1);
  });
  c.linesRef.material.opacity = alpha * 0.55;
}

// ── Animation loop ────────────────────────────────────────────────────────────
let frameCount = 0;
const clock = new THREE.Clock();

function animate() {
  requestAnimationFrame(animate);
  const t  = clock.getElapsedTime();
  const dt = Math.min(0.033, clock.getDelta() || 0.016);
  frameCount++;

  // Mode switching
  if (lastModeSwitch === 0) lastModeSwitch = t;
  if (modeBlend < 1) {
    modeBlend = Math.min(1, modeBlend + dt / MODE_BLEND_TIME);
    if (modeBlend >= 1) {
      modeIdx = nextModeIdx;
      lastModeSwitch = t;
    }
  } else if (t - lastModeSwitch > MODE_DURATION) {
    pickNextMode();
  }

  // Mode params (interpolés)
  const driftScale  = blendedNum('driftScale');
  const opacBase    = blendedNum('nodeOpacityBase');
  const opacAmp     = blendedNum('nodeOpacityAmp');
  const swirl       = blendedNum('swirl');

  // Twinkle subtil du fond étoilé
  starMat.opacity = 0.78 + 0.18 * Math.sin(t * 0.4);

  // Icosaèdres (forme terrestre, inchangée par le mode)
  ico.rotation.x  = t * 0.08;
  ico.rotation.y  = t * 0.11;
  ico2.rotation.x = t * 0.05;
  ico2.rotation.y = -t * 0.07;

  // Nodes
  nodes.forEach(node => {
    const ud = node.userData;

    // Drift + swirl (rotation orbitale légère autour du centre, surtout en mode vortex/galaxy)
    if (swirl !== 0) {
      const x = node.position.x, z = node.position.z;
      const cos = Math.cos(swirl), sin = Math.sin(swirl);
      node.position.x = x * cos - z * sin;
      node.position.z = x * sin + z * cos;
    }
    node.position.x += ud.vx * driftScale;
    node.position.y += ud.vy * driftScale;
    node.position.z += ud.vz * driftScale;
    node.position.y += Math.sin(t * 0.6 + ud.phase) * 0.002;

    // Boundary wrap
    const B = SPREAD;
    if (node.position.x >  B) node.position.x = -B;
    if (node.position.x < -B) node.position.x =  B;
    if (node.position.y >  B * 0.7) node.position.y = -B * 0.7;
    if (node.position.y < -B * 0.7) node.position.y =  B * 0.7;
    if (node.position.z >  B) node.position.z = -B;
    if (node.position.z < -B) node.position.z =  B;

    // Couleur (cross-fadée selon le mode)
    const col = blendedColor(ud.paletteIdx);
    node.material.color.copy(col);
    node.material.opacity = opacBase + opacAmp * Math.sin(t * 1.2 + ud.phase);
  });

  // Rebuild lines périodiquement
  if (frameCount % 6 === 0) buildLines();

  // Constellations en arrière-plan : fade in → hold → fade out → switch
  // + effet de zoom avant/arrière sur les côtés (scaleX) pendant les transitions
  constTimer += dt;
  const hold = CONST_INTERVAL - 2 * CONST_FADE;
  let alpha;
  let zoomScale = 1;
  if (constTimer < CONST_FADE) {
    // Fade in : opacity 0→peak, scaleX 1+amp → 1 (zoom avant, les côtés se resserrent)
    const p = constTimer / CONST_FADE;
    const eased = 1 - Math.pow(1 - p, 3);  // easeOutCubic
    alpha = p * CONST_PEAK_OP;
    zoomScale = 1 + CONST_ZOOM_AMP * (1 - eased);
  } else if (constTimer < CONST_FADE + hold) {
    alpha = CONST_PEAK_OP;
    zoomScale = 1;
  } else if (constTimer < CONST_INTERVAL) {
    // Fade out : opacity peak→0, scaleX 1 → 1+amp (zoom arrière, les côtés s'écartent)
    const p = (constTimer - CONST_FADE - hold) / CONST_FADE;
    const eased = Math.pow(p, 2);  // easeInQuad
    alpha = (1 - p) * CONST_PEAK_OP;
    zoomScale = 1 + CONST_ZOOM_AMP * eased;
  } else {
    // Switch — masque/reset l'ancienne, passe à la suivante
    const old = CONSTELLATIONS[constIdx];
    setConstellationAlpha(old, 0);
    old.group.scale.set(1, 1, 1);
    constIdx = (constIdx + 1) % CONSTELLATIONS.length;
    constTimer = 0;
    alpha = 0;
    zoomScale = 1 + CONST_ZOOM_AMP;  // démarre élargi (effet "zoom in" à venir)
  }
  // Légère rotation lente du groupe pour donner de la vie
  const cur = CONSTELLATIONS[constIdx];
  cur.group.rotation.z = Math.sin(t * 0.05) * 0.04;
  // Applique le zoom : scaleX étend les côtés, scaleY/Z restent neutres
  cur.group.scale.x = zoomScale;
  cur.group.scale.y = 1 + (zoomScale - 1) * 0.25;  // léger effet vertical pour cohérence
  setConstellationAlpha(cur, alpha);

  // Masque les autres + reset leur scale (au cas où après resize/HMR)
  CONSTELLATIONS.forEach((c, i) => {
    if (i !== constIdx) {
      setConstellationAlpha(c, 0);
      c.group.scale.set(1, 1, 1);
    }
  });

  // Label HTML (apparaît avec la constellation)
  if (labelEl && labelNameEl && labelFactEl) {
    labelNameEl.textContent = cur.name;
    labelFactEl.textContent = cur.fact;
    labelEl.style.opacity = String(Math.min(1, alpha / CONST_PEAK_OP * 0.95));
  }

  // Rotation lente de la caméra autour du centre (effet "vol spatial")
  const orbit = t * 0.025;
  camera.position.x = Math.sin(orbit) * 1.8;
  camera.position.y = Math.sin(t * 0.06) * 0.9;
  camera.lookAt(scene.position);

  renderer.render(scene, camera);
}

animate();
</script>
