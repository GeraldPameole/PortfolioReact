// Couleur thématique du tracé de chaque constellation (chacune a sa
// signature visuelle ; couleurs choisies en lien avec l'étoile dominante
// ou la mythologie : Hydre/eau=turquoise, Cygne=blanc pur, Antarès=rouge…)
const CONST_LINE_COLOR = {
  'Hydre':         0x06b6d4,   // cyan turquoise (l'hydre aquatique)
  'Éridan':        0x6366f1,   // indigo (le fleuve nocturne)
  'Centaure':      0xd946ef,   // magenta (mythologique)
  'Poupe':         0xfb923c,   // ambre (bois de navire)
  'Carène':        0xfbbf24,   // or (Canopus, étoile éclatante)
  'Voiles':        0xbae6fd,   // bleu pâle (voiles claires)
  'Hercule':       0xa78bfa,   // violet royal (héros divin)
  'Grande Ourse':  0x60a5fa,   // bleu clair
  'Petite Ourse':  0x7dd3fc,   // cyan glacé (pôle Nord)
  'Orion':         0xf97316,   // orange ardent (Bételgeuse rouge)
  'Cassiopée':     0xf472b6,   // rose (reine)
  'Cygne':         0xffffff,   // blanc pur
  'Lion':          0xfacc15,   // or félin
  'Scorpion':      0xdc2626,   // rouge sang (Antarès)
  'Taureau':       0xea580c,   // orange (Aldébaran)
  'Gémeaux':       0x818cf8,   // bleu-violet (duo)
  'Lyre':          0x34d399,   // vert émeraude (Véga)
};
const constMatBase = { star: 0xd8e3ff, starBright: 0xffd96a };

CONSTELLATIONS.forEach(c => {
  const g = new THREE.Group();
  g.position.set(0, 0, BG_Z);

  const lineCol = CONST_LINE_COLOR[c.name] ?? 0x6da3ff;

  c.starsRef = [];
  c.stars.forEach((p, i) => {
    const special = c.specials.find(s => s.index === i);
    const r = special ? special.size : 0.16;
    const mat = new THREE.MeshBasicMaterial({
      color: special ? constMatBase.starBright : constMatBase.star,
      transparent: true,
      opacity: 0,
    });
    const sphere = new THREE.Mesh(new THREE.SphereGeometry(r, 12, 12), mat);
    sphere.position.set(p[0] * CONST_SCALE_X, p[1] * CONST_SCALE_Y, 0);
    g.add(sphere);
    c.starsRef.push(sphere);

    // Halo subtil pour les étoiles brillantes notables
    if (special) {
      const haloMat = new THREE.MeshBasicMaterial({
        color: constMatBase.starBright,
        transparent: true,
        opacity: 0,
      });
      const halo = new THREE.Mesh(new THREE.SphereGeometry(r * 2.4, 14, 14), haloMat);
      halo.position.copy(sphere.position);
      halo.userData.isHalo = true;
      g.add(halo);
      c.starsRef.push(halo);
    }
  });

  // Lines avec couleur thématique propre à la constellation
  const positions = [];
  c.edges.forEach(([a, b]) => {
    const pa = c.stars[a], pb = c.stars[b];
    positions.push(pa[0] * CONST_SCALE_X, pa[1] * CONST_SCALE_Y, 0);
    positions.push(pb[0] * CONST_SCALE_X, pb[1] * CONST_SCALE_Y, 0);
  });
  const lineGeo = new THREE.BufferGeometry();
  lineGeo.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
  const lineMatC = new THREE.LineBasicMaterial({
    color: lineCol,
    linewidth: 2,            // (ignoré par WebGL standard mais utile en doc)
    transparent: true,
    opacity: 0,
    blending: THREE.AdditiveBlending,
  });
  c.linesRef = new THREE.LineSegments(lineGeo, lineMatC);
  // On utilise un Group avec 2 passes pour épaissir visuellement la ligne
  // (additive blending) — donne une vraie présence à la couleur
  const lineMatGlow = new THREE.LineBasicMaterial({
    color: lineCol,
    transparent: true,
    opacity: 0,
    blending: THREE.AdditiveBlending,
  });
  c.linesGlow = new THREE.LineSegments(lineGeo.clone(), lineMatGlow);
  c.linesGlow.scale.set(1.02, 1.02, 1.02);
  g.add(c.linesGlow);
  g.add(c.linesRef);

  scene.add(g);
  c.group = g;
});

// État du cycle constellation
let constIdx     = 0;
let constTimer   = 0;
const CONST_INTERVAL = 6;         // 6s par constellation (cycle complet)
const CONST_FADE     = 0.9;       // 0.9s fade in / out
const CONST_PEAK_OP  = 0.9;       // opacité max (constellations bien visibles)
const CONST_ZOOM_AMP = 0.6;       // (utilisé pour le zoom inclusif)
const CONST_Z_OFFSET = 14;        // distance Z parcourue à chaque switch (zoom inclusif)

const labelEl     = document.getElementById('three-bg-label');
const labelNameEl = labelEl?.querySelector('[data-cn-name]');
const labelFactEl = labelEl?.querySelector('[data-cn-fact]');

function setConstellationAlpha(c, alpha) {
  c.starsRef.forEach(s => {
    const isHalo = s.userData && s.userData.isHalo;
    s.material.opacity = alpha * (isHalo ? 0.5 : 1);
  });
  // Tracés très lisibles : ligne principale + ligne glow plus large
  c.linesRef.material.opacity = alpha * 0.95;
  if (c.linesGlow) c.linesGlow.material.opacity = alpha * 0.55;
}

// ── Animation loop ────────────────────────────────────────────────────────────
let frameCount = 0;
const clock = new THREE.Clock();

function animate() {
  requestAnimationFrame(animate);
  const t  = clock.getElapsedTime();
  const dt = Math.min(0.033, clock.getDelta() || 0.016);
  frameCount++;

  // Mode switching
  if (lastModeSwitch === 0) lastModeSwitch = t;
  if (modeBlend < 1) {
    modeBlend = Math.min(1, modeBlend + dt / MODE_BLEND_TIME);
    if (modeBlend >= 1) {
      modeIdx = nextModeIdx;
      lastModeSwitch = t;
    }
  } else if (t - lastModeSwitch > MODE_DURATION) {
    pickNextMode();
  }

  // Mode params (interpolés)
  const driftScale  = blendedNum('driftScale');
  const opacBase    = blendedNum('nodeOpacityBase');
  const opacAmp     = blendedNum('nodeOpacityAmp');
  const swirl       = blendedNum('swirl');

  // Twinkle subtil du fond étoilé
  starMat.opacity = 0.85 + 0.12 * Math.sin(t * 0.4);
  brightMat.opacity = 0.85 + 0.15 * Math.sin(t * 0.8 + 1.2);

  // Rotation très lente de tout le champ stellaire (effet "cosmos qui tourne")
  starfield.rotation.y = t * 0.008;
  starfield.rotation.x = Math.sin(t * 0.02) * 0.05;
  brightStars.rotation.y = t * 0.008;

  // Expansion de l'Univers : "breathing" subtil du champ stellaire
  // (les étoiles dérivent légèrement vers l'extérieur puis reviennent)
  const expansion = 1 + Math.sin(t * 0.04) * 0.04;
  starfield.scale.setScalar(expansion);
  brightStars.scale.setScalar(expansion);

  // Animation des nuages galactiques — drift + rotation + twinkle + cycle de
  // profondeur (chaque nuage part du lointain, vient au premier plan, repart)
  nebulaClouds.forEach((c, i) => {
    // Cycle de présence (0 → 1 → 0 en sinusoïde lisse)
    const cycle = (t / c.cycleDuration + c.cyclePhase) % 1;
    const presence = 0.5 - 0.5 * Math.cos(cycle * 2 * Math.PI);
    // Z varie : très loin (fog atténue à zéro) → proche (visible)
    const z = c.zFar + (c.zNear - c.zFar) * presence;

    // Drift sinusoïdal autour de la position de base
    c.mesh.position.x = c.basePosition.x + Math.sin(t * c.driftSpeed + c.driftPhase) * 2.5;
    c.mesh.position.y = c.basePosition.y + Math.cos(t * c.driftSpeed * 0.7 + c.driftPhase) * 1.8;
    c.mesh.position.z = z;
    // Rotation lente sur Z
    c.mesh.rotation.z += c.rotSpeed * dt * 2;
    // Twinkle d'opacité × présence (fade in/out lié à la profondeur)
    const twinkle = c.twinkleBase + c.twinkleAmp * Math.sin(t * 0.3 + c.twinklePhase);
    const opacityFactor = Math.pow(presence, 1.3);  // accentue la disparition
    c.mat.opacity = twinkle * opacityFactor;
  });

  // Planètes orbitales : cycle apparition (du lointain) → présence → disparition
  // chacune a son propre rythme, profondeur et déphasage
  let earthRef = null;
  let earthPresence = 0;
  planets.forEach(p => {
    // Cycle de présence (0 → 1 → 0 en sinusoïde lisse)
    const cycle = (t / p.cycleDuration + p.cyclePhase) % 1;
    const presence = 0.5 - 0.5 * Math.cos(cycle * 2 * Math.PI);   // 0 ↗ 1 ↘ 0
    // Z varie entre zFar (loin, invisible) et zNear (proche, visible)
    const zBase = p.zFar + (p.zNear - p.zFar) * presence;

    // Orbite XY (toujours active)
    const angle = t * p.orbitSpeed + p.phase;
    p.mesh.position.x = Math.cos(angle) * p.orbitR;
    p.mesh.position.y = Math.sin(angle) * p.orbitR * 0.35 + p.orbitTilt * p.orbitR;
    p.mesh.position.z = zBase + Math.sin(angle) * 2;
    p.mesh.rotation.y += dt * p.spinSpeed;

    // Fade in/out via opacité (en plus du fog qui atténue déjà la lumière)
    // Courbe en puissance 1.4 pour que la "disparition" soit plus marquée
    const opacityFactor = Math.pow(presence, 1.4);
    p.tracked.forEach(entry => { entry.m.opacity = entry.peak * opacityFactor; });

    if (p.isEarth) { earthRef = p; earthPresence = presence; }
  });

  // Lune : orbite autour de la Terre, visible quand la Terre l'est
  if (earthRef) {
    const moonAng = t * MOON_ORBIT_SPEED;
    moon.position.x = earthRef.mesh.position.x + Math.cos(moonAng) * MOON_ORBIT_R;
    moon.position.y = earthRef.mesh.position.y + Math.sin(moonAng) * MOON_ORBIT_R * 0.4;
    moon.position.z = earthRef.mesh.position.z + Math.sin(moonAng) * 0.6;
    const moonOpacity = Math.pow(earthPresence, 1.4);
    moonMat.opacity     = 0.9  * moonOpacity;
    moonHaloMat.opacity = 0.25 * moonOpacity;
    // L'anneau d'orbite de la Lune suit la Terre
    moonOrbitVis.line.position.copy(earthRef.mesh.position);
    moonOrbitVis.mat.opacity = moonOrbitVis.peak * moonOpacity;
  }

  // Anneaux orbitaux des planètes : opacité légère oscillante (subtilité)
  const ringPulse = 0.7 + 0.3 * Math.sin(t * 0.2);
  earthOrbitVis.mat.opacity   = earthOrbitVis.peak * ringPulse;
  jupiterOrbitVis.mat.opacity = jupiterOrbitVis.peak * ringPulse;
  saturnOrbitVis.mat.opacity  = saturnOrbitVis.peak * ringPulse;

  // Icosaèdres (forme terrestre, inchangée par le mode)
  ico.rotation.x  = t * 0.08;
  ico.rotation.y  = t * 0.11;
  ico2.rotation.x = t * 0.05;
  ico2.rotation.y = -t * 0.07;

  // Nodes
  nodes.forEach(node => {
    const ud = node.userData;

    // Drift + swirl (rotation orbitale légère autour du centre, surtout en mode vortex/galaxy)
    if (swirl !== 0) {
      const x = node.position.x, z = node.position.z;
      const cos = Math.cos(swirl), sin = Math.sin(swirl);
      node.position.x = x * cos - z * sin;
      node.position.z = x * sin + z * cos;
    }
    node.position.x += ud.vx * driftScale;
    node.position.y += ud.vy * driftScale;
    node.position.z += ud.vz * driftScale;
    node.position.y += Math.sin(t * 0.6 + ud.phase) * 0.002;

    // Boundary wrap
    const B = SPREAD;
    if (node.position.x >  B) node.position.x = -B;
    if (node.position.x < -B) node.position.x =  B;
    if (node.position.y >  B * 0.7) node.position.y = -B * 0.7;
    if (node.position.y < -B * 0.7) node.position.y =  B * 0.7;
    if (node.position.z >  B) node.position.z = -B;
    if (node.position.z < -B) node.position.z =  B;

    // Couleur (cross-fadée selon le mode)
    const col = blendedColor(ud.paletteIdx);
    node.material.color.copy(col);
    node.material.opacity = opacBase + opacAmp * Math.sin(t * 1.2 + ud.phase);
  });

  // Rebuild lines périodiquement
  if (frameCount % 6 === 0) buildLines();

  // Constellations en arrière-plan : fade in → hold → fade out → switch
  // ZOOM INCLUSIF : à chaque switch, la constellation arrive du lointain
  // (z = BG_Z - CONST_Z_OFFSET) et se rapproche de la caméra (z = BG_Z).
  // À la disparition, elle continue d'avancer (z = BG_Z + CONST_Z_OFFSET)
  // tout en se dilatant uniformément (scale 1 → 1.6) pour "englober" l'écran.
  constTimer += dt;
  const hold = CONST_INTERVAL - 2 * CONST_FADE;
  let alpha;
  let zoomScale = 1;
  let zPos = BG_Z;
  if (constTimer < CONST_FADE) {
    // Fade in : opacity 0→peak, scale 0.45→1.0, z avance vers la caméra
    const p = constTimer / CONST_FADE;
    const eased = 1 - Math.pow(1 - p, 3);  // easeOutCubic
    alpha = p * CONST_PEAK_OP;
    zoomScale = 0.45 + 0.55 * eased;
    zPos = BG_Z - CONST_Z_OFFSET * (1 - eased);
  } else if (constTimer < CONST_FADE + hold) {
    alpha = CONST_PEAK_OP;
    zoomScale = 1;
    zPos = BG_Z;
  } else if (constTimer < CONST_INTERVAL) {
    // Fade out : opacity peak→0, scale 1.0→1.6, z continue d'avancer
    const p = (constTimer - CONST_FADE - hold) / CONST_FADE;
    const eased = Math.pow(p, 2);  // easeInQuad
    alpha = (1 - p) * CONST_PEAK_OP;
    zoomScale = 1 + CONST_ZOOM_AMP * eased;
    zPos = BG_Z + CONST_Z_OFFSET * eased;
  } else {
    // Switch — masque/reset l'ancienne, passe à la suivante
    const old = CONSTELLATIONS[constIdx];
    setConstellationAlpha(old, 0);
    old.group.scale.set(1, 1, 1);
    old.group.position.z = BG_Z;
    constIdx = (constIdx + 1) % CONSTELLATIONS.length;
    constTimer = 0;
    alpha = 0;
    zoomScale = 0.45;            // démarre tout petit (zoom in à venir)
    zPos = BG_Z - CONST_Z_OFFSET;  // démarre loin
  }
  // Légère rotation lente du groupe pour donner de la vie
  const cur = CONSTELLATIONS[constIdx];
  cur.group.rotation.z = Math.sin(t * 0.05) * 0.04;
  // Zoom inclusif : scale uniforme + translate Z vers la caméra
  cur.group.scale.setScalar(zoomScale);
  cur.group.position.z = zPos;
  setConstellationAlpha(cur, alpha);

  // Masque les autres + reset leur position/scale (au cas où après resize/HMR)
  CONSTELLATIONS.forEach((c, i) => {
    if (i !== constIdx) {
      setConstellationAlpha(c, 0);
      c.group.scale.set(1, 1, 1);
      c.group.position.z = BG_Z;
    }
  });

  // Label HTML (apparaît avec la constellation)
  if (labelEl && labelNameEl && labelFactEl) {
    labelNameEl.textContent = cur.name;
    labelFactEl.textContent = cur.fact;
    labelEl.style.opacity = String(Math.min(1, alpha / CONST_PEAK_OP * 0.95));
  }

  // Intro zoom cosmique : caméra recule de l'échelle humaine (z=4) vers
  // l'échelle cosmique (z=28) avec easing easeOutQuart, puis orbite douce.
  if (introProgress < 1) {
    introProgress = Math.min(1, introProgress + dt / INTRO_DURATION);
    const eased = 1 - Math.pow(1 - introProgress, 4);  // easeOutQuart
    camera.position.z = CAMERA_START_Z + (CAMERA_END_Z - CAMERA_START_Z) * eased;
    // Pendant l'intro, garde la caméra centrée (pas d'orbite encore)
    camera.position.x = 0;
    camera.position.y = 0;
  } else {
    // Après l'intro : orbite douce continue (effet "vol spatial")
    const orbit = (t - INTRO_DURATION) * 0.025;
    camera.position.z = CAMERA_END_Z;
    camera.position.x = Math.sin(orbit) * 1.8;
    camera.position.y = Math.sin((t - INTRO_DURATION) * 0.06) * 0.9;
  }
  camera.lookAt(scene.position);

  renderer.render(scene, camera);
}

animate();
</script>
