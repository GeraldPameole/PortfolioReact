---
import ThreeBackground from './ThreeBackground.astro';
interface Props {
  showCanvas?: boolean;
}
const { showCanvas = true } = Astro.props;
---

<section class="hero">
  {showCanvas && <ThreeBackground />}
  <div class="orb orb-violet" style="width:600px;height:600px;top:-150px;left:-100px;opacity:0.25;pointer-events:none;z-index:0;"></div>
  <div class="orb orb-cyan"   style="width:400px;height:400px;top:100px;right:-80px;opacity:0.18;pointer-events:none;z-index:0;"></div>

  <div class="hero-content">
    <div class="hero-tag reveal">
      <span class="tag-dot"></span>
      Disponible pour de nouveaux projets
    </div>

    <h1 class="hero-title reveal reveal-delay-1">
      <span class="name-line">Gérald Paméole</span>
      <span class="title-line gradient-text">Chef de projet & Expert digital</span>
    </h1>

    <p class="hero-desc reveal reveal-delay-2">
      20 ans d'expérience en <strong>gestion de projet télécom</strong>, management d'équipes et
      transformation digitale. Je transforme la complexité en résultats mesurables.
    </p>

    <div class="hero-stats reveal reveal-delay-3">
      <div class="stat"><span class="stat-val gradient-text">20+</span><span class="stat-lbl">Années d'exp.</span></div>
      <div class="stat-sep"></div>
      <div class="stat"><span class="stat-val gradient-text">200+</span><span class="stat-lbl">Formés</span></div>
      <div class="stat-sep"></div>
      <div class="stat"><span class="stat-val gradient-text">40+</span><span class="stat-lbl">Projets livrés</span></div>
    </div>

    <div class="hero-actions reveal reveal-delay-4">
      <a href="/projets" class="btn btn-primary">
        Voir mes projets
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
      </a>
      <a href="/assets/cv-gerald-pameole.pdf" download class="btn btn-secondary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Télécharger le CV
      </a>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <div class="scroll-line"></div>
      <span>Défiler</span>
    </div>
  </div>

  <div class="hero-badges" aria-hidden="true">
    <div class="badge badge-1 animate-float">Agile / Scrum</div>
    <div class="badge badge-2 animate-float" style="animation-delay:1.2s">PMP Certified</div>
    <div class="badge badge-3 animate-float" style="animation-delay:0.6s">Full Stack Dev</div>
    <div class="badge badge-4 animate-float" style="animation-delay:1.8s">Team Lead</div>
  </div>
</section>

<style>
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  padding: 8rem 1.5rem 5rem;
}
/* Three.js canvas handled by ThreeBackground component */
#hero-canvas-unused {
  display: none;
}
.hero-content {
  position: relative;
  z-index: 2;
  max-width: 860px;
  text-align: center;
}
.hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-mono);
  font-size: 0.82rem;
  letter-spacing: 0.06em;
  color: var(--green);
  margin-bottom: 2rem;
  padding: 0.4rem 1.1rem;
  background: rgba(0,245,160,0.08);
  border: 1px solid rgba(0,245,160,0.2);
  border-radius: var(--r-full);
}
.tag-dot {
  width: 7px; height: 7px;
  background: var(--green);
  border-radius: 50%;
  box-shadow: 0 0 8px var(--green);
  animation: glow-pulse 2s ease-in-out infinite;
}
.hero-title {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  margin-bottom: 1.75rem;
  letter-spacing: -0.03em;
}
.name-line  { color: var(--text-1); display: block; font-size: clamp(2.8rem, 7vw, 5.5rem); }
.title-line { display: block; font-size: clamp(1.4rem, 3.2vw, 2.4rem); font-weight: 500; letter-spacing: -0.02em; }
.hero-desc {
  font-size: 1.08rem;
  color: var(--text-3);
  max-width: 560px;
  margin: 0 auto 2.5rem;
  line-height: 1.85;
}
.hero-desc strong { color: var(--text-2); font-weight: 600; }
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  margin-bottom: 3rem;
  flex-wrap: wrap;
}
.stat { text-align: center; }
.stat-val { display: block; font-family: var(--font-sans); font-size: 2.1rem; font-weight: 700; line-height: 1; }
.stat-lbl { font-size: 0.78rem; color: var(--text-3); letter-spacing: 0.05em; margin-top: 0.3rem; display: block; }
.stat-sep { width: 1px; height: 38px; background: var(--border); }
.hero-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 4rem;
  flex-wrap: wrap;
}
.hero-scroll {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  color: var(--text-4);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-family: var(--font-mono);
}
.scroll-line {
  width: 1px; height: 40px;
  background: linear-gradient(to bottom, var(--violet), transparent);
  animation: float 2s ease-in-out infinite;
}
.hero-badges { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
.badge {
  position: absolute;
  font-family: var(--font-mono);
  font-size: 0.73rem;
  font-weight: 500;
  color: var(--text-3);
  padding: 0.45rem 0.9rem;
  background: var(--glass);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  backdrop-filter: blur(8px);
  white-space: nowrap;
}
.badge-1 { top: 22%; left: 6%; }
.badge-2 { top: 28%; right: 6%; }
.badge-3 { bottom: 30%; left: 8%; }
.badge-4 { bottom: 26%; right: 8%; }
@media (max-width: 768px) {
  .hero-badges, .stat-sep { display: none; }
  .hero-stats { gap: 1.5rem; }
}
</style>

<script is:inline>
(function() {
  // Canvas animation replaced by Three.js (ThreeBackground component)
  return;
  const ctx = canvas.getContext('2d');
  let W, H, raf;
  const particles = [];
  const N = 75, CONNECT = 125, SPEED = 0.35;
  const mouse = { x: -999, y: -999 };

  function resize() {
    W = canvas.width  = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
  }

  function mkParticle() {
    return {
      x:  Math.random() * W,
      y:  Math.random() * H,
      vx: (Math.random() - 0.5) * SPEED,
      vy: (Math.random() - 0.5) * SPEED,
      r:  Math.random() * 1.8 + 0.8,
      isViolet: Math.random() > 0.5,
    };
  }

  function init() {
    resize();
    particles.length = 0;
    for (let i = 0; i < N; i++) particles.push(mkParticle());
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    for (let i = 0; i < N; i++) {
      const p = particles[i];
      for (let j = i + 1; j < N; j++) {
        const q = particles[j];
        const dx = p.x - q.x, dy = p.y - q.y;
        const d = Math.sqrt(dx * dx + dy * dy);
        if (d < CONNECT) {
          const a = (1 - d / CONNECT) * 0.3;
          ctx.beginPath();
          ctx.strokeStyle = p.isViolet ? `rgba(145,94,255,${a})` : `rgba(0,207,253,${a})`;
          ctx.lineWidth = 0.7;
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(q.x, q.y);
          ctx.stroke();
        }
      }
    }

    for (let i = 0; i < N; i++) {
      const p = particles[i];
      const dx = p.x - mouse.x, dy = p.y - mouse.y;
      const md = Math.sqrt(dx * dx + dy * dy);
      if (md < 90 && md > 0) {
        const f = (90 - md) / 90 * 0.7;
        p.vx += (dx / md) * f;
        p.vy += (dy / md) * f;
      }
      p.vx *= 0.98; p.vy *= 0.98;
      p.x  += p.vx;  p.y  += p.vy;
      if (p.x < 0)  { p.x = 0;  p.vx *= -1; }
      if (p.x > W)  { p.x = W;  p.vx *= -1; }
      if (p.y < 0)  { p.y = 0;  p.vy *= -1; }
      if (p.y > H)  { p.y = H;  p.vy *= -1; }

      const color = p.isViolet ? '145,94,255' : '0,207,253';
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${color},0.75)`;
      ctx.fill();
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${color},0.08)`;
      ctx.fill();
    }

    raf = requestAnimationFrame(draw);
  }

  const onResize = () => { cancelAnimationFrame(raf); init(); draw(); };
  window.addEventListener('resize', onResize, { passive: true });
  canvas.parentElement?.addEventListener('mousemove', e => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  }, { passive: true });
  canvas.parentElement?.addEventListener('mouseleave', () => { mouse.x = -999; mouse.y = -999; });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => { init(); draw(); });
  } else {
    init(); draw();
  }
})();
</script>
