---
const LINKS = [
  { label: 'Accueil',     href: '/' },
  { label: 'Projets',     href: '/projets' },
  { label: 'Articles',    href: '/blog' },
  { label: 'Compétences', href: '/skills' },
  { label: 'Livres',      href: '/livres' },
  { label: 'À propos',    href: '/about' },
  { label: 'Contact',     href: '/contact' },
];
const SOCIALS = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/geraldpameole/' },
  { label: 'GitHub',   href: 'https://github.com/gpameole' },
  { label: 'CodePen',  href: 'https://codepen.io/gpameole' },
];
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-glow-line"></div>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo"><span class="lb">&lt;</span><span class="ln">GP</span><span class="lb">/&gt;</span></a>
        <p class="footer-tagline">Chef de projet Pilotage d'Activité & Expert en digitalisation.<br/>20 ans d'expérience à la croisée de la formation, des relations client, du développement web et du télécom — avec le management et le pilotage de projet comme fil rouge.</p>
        <div class="footer-socials">
          {SOCIALS.map(s => <a href={s.href} target="_blank" rel="noopener noreferrer" class="social-pill">{s.label}</a>)}
        </div>
      </div>

      <div class="footer-nav">
        <p class="fnav-title">Navigation</p>
        <ul>
          {LINKS.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <div class="footer-contact">
        <p class="fnav-title">Contact</p>
        <a href="mailto:gerald.pameole@gmail.com" class="contact-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
          gerald.pameole@gmail.com
        </a>
        <a href="https://www.linkedin.com/in/geraldpameole/" target="_blank" rel="noopener noreferrer" class="contact-item">
          <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          LinkedIn
        </a>
        <a href="/contact" class="btn btn-secondary" style="margin-top:1.25rem;font-size:0.875rem;padding:0.6rem 1.4rem;">Discutons →</a>
      </div>
    </div>

    <div class="footer-newsletter">
      <div class="fnl-text">
        <p class="fnav-title" style="margin-bottom:0">Newsletter</p>
        <span class="fnl-tagline">Un article par semaine, sans bruit.</span>
      </div>
      <form
        id="footer-nl-form"
        action="https://buttondown.com/api/emails/embed-subscribe/Apex_971"
        method="POST"
        class="fnl-form"
      >
        <input type="hidden" name="tag" value="footer" />
        <input
          type="email"
          name="email"
          required
          placeholder="votre@email.com"
          class="fnl-input"
          autocomplete="email"
          aria-label="Votre adresse email"
        />
        <button type="submit" class="fnl-btn" aria-label="S'abonner à la newsletter">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
        </button>
        <span class="fnl-success" role="status" hidden>Inscrit ✓</span>
      </form>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© {year} Gérald Paméole — <a href="/mentions-legales" style="color:inherit;text-decoration:underline;text-underline-offset:2px;opacity:0.7">Mentions légales</a></p>
      <div class="footer-tech">
        Construit avec&nbsp;
        <span class="tech-tag">Astro</span>
        <span class="tech-tag">React</span>
        <span class="tech-tag">Tailwind</span>
      </div>
    </div>
  </div>
</footer>

<style>
.footer { background:var(--bg-1); border-top:1px solid var(--border); padding:4rem 0 2rem; position:relative; z-index:1; }
.footer-glow-line { position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,var(--violet),var(--cyan),transparent); opacity:0.45; }
.footer-grid { display:grid; grid-template-columns:2fr 1fr 1.5fr; gap:3rem; padding-bottom:3rem; border-bottom:1px solid var(--border); margin-bottom:2rem; }
.footer-logo { font-family:var(--font-mono); font-size:1.2rem; font-weight:600; color:var(--text-1); text-decoration:none; display:inline-flex; gap:0.1em; margin-bottom:1rem; }
.lb { color:var(--violet); }
.ln { color:var(--cyan); }
.footer-tagline { color:var(--text-3); font-size:0.875rem; line-height:1.75; margin-bottom:1.5rem; }
.footer-socials { display:flex; gap:0.5rem; flex-wrap:wrap; }
.social-pill { font-size:0.78rem; font-weight:600; font-family:var(--font-sans); color:var(--text-3); text-decoration:none; padding:0.28rem 0.8rem; border:1px solid var(--border); border-radius:var(--r-full); transition:all .2s; }
.social-pill:hover { color:var(--violet-light); border-color:rgba(145,94,255,.4); background:rgba(145,94,255,.08); }
.fnav-title { font-family:var(--font-sans); font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--text-3); margin-bottom:1.25rem; }
.footer-nav ul { list-style:none; padding:0; display:flex; flex-direction:column; gap:0.6rem; }
.footer-nav a { color:var(--text-3); text-decoration:none; font-size:0.9rem; transition:color .2s; }
.footer-nav a:hover { color:var(--text-1); }
.footer-contact { display:flex; flex-direction:column; gap:0.75rem; }
.contact-item { display:flex; align-items:center; gap:0.6rem; color:var(--text-3); text-decoration:none; font-size:0.875rem; transition:color .2s; }
.contact-item:hover { color:var(--text-1); }
.footer-bottom { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; }
.footer-copy { color:var(--text-4); font-size:0.82rem; }
.footer-tech { display:flex; align-items:center; gap:0.4rem; color:var(--text-4); font-size:0.8rem; }
.tech-tag { background:var(--glass); border:1px solid var(--border); border-radius:var(--r-sm); padding:0.12rem 0.5rem; font-family:var(--font-mono); font-size:0.72rem; color:var(--text-3); }
/* Mini-formulaire newsletter (compact) */
.footer-newsletter { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1.5rem; padding:1.5rem 0; border-top:1px solid var(--border); margin-bottom:1.5rem; }
.fnl-text { display:flex; flex-direction:column; gap:0.2rem; }
.fnl-tagline { font-size:0.85rem; color:var(--text-3); }
.fnl-form { display:flex; align-items:center; gap:0.5rem; min-width:280px; }
.fnl-input { flex:1; background:var(--bg-2); border:1px solid var(--border); border-radius:var(--r-md); padding:0.55rem 0.9rem; font-size:0.85rem; color:var(--text-1); font-family:var(--font-sans); transition:border-color .2s; }
.fnl-input:focus { outline:none; border-color:var(--violet); box-shadow:0 0 0 3px rgba(145,94,255,.12); }
.fnl-btn { background:var(--violet); border:none; color:#fff; border-radius:var(--r-md); width:38px; height:38px; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; transition:background .2s; }
.fnl-btn:hover { background:var(--violet-light, #a78bfa); }
.fnl-btn[disabled] { opacity:.6; cursor:default; }
.fnl-success { color:#86efac; font-size:0.9rem; font-weight:600; }
@media(max-width:900px){ .footer-grid{grid-template-columns:1fr 1fr;} .footer-brand{grid-column:1/-1;} }
@media(max-width:600px){ .footer-grid{grid-template-columns:1fr;} .footer-bottom{flex-direction:column;align-items:flex-start;} .footer-newsletter{flex-direction:column;align-items:stretch;} .fnl-form{width:100%;} }
</style>

<script>
document.addEventListener('astro:page-load', () => {
  const form = document.getElementById('footer-nl-form') as HTMLFormElement | null;
  if (!form) return;
  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
  const input = form.querySelector('input[type="email"]') as HTMLInputElement;
  const success = form.querySelector('.fnl-success') as HTMLElement;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }
    btn.disabled = true;
    try {
      // Buttondown embed-subscribe : no-cors + succès optimiste
      await fetch(form.action, { method: 'POST', mode: 'no-cors', body: new FormData(form) });
      input.hidden = true;
      btn.hidden = true;
      success.hidden = false;
    } catch {
      btn.disabled = false;
    }
  });
});
</script>
