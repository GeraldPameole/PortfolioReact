<button id="back-to-top" class="btt" aria-label="Retour en haut" hidden>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="m18 15-6-6-6 6"/>
  </svg>
</button>

<style>
.btt {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  z-index: 100;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--bg-2);
  border: 1px solid var(--border-bright);
  color: var(--text-2);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all .25s var(--ease-out);
  backdrop-filter: blur(12px);
  box-shadow: var(--shadow-md);
}
.btt:hover {
  background: var(--violet);
  border-color: var(--violet);
  color: white;
  transform: translateY(-3px);
  box-shadow: var(--glow-violet);
}
</style>

<script is:inline>
// Init idempotente — survit aux ViewTransitions d'Astro 4 (qui ne ré-exécutent
// pas les <script is:inline> après une navigation client-side).
function initBackToTop() {
  const btn = document.getElementById('back-to-top');
  if (!btn || btn.dataset.bound) return;
  btn.dataset.bound = '1';
  // Affiche/cache selon le scroll courant (idempotent : on (re)pose un seul listener)
  const onScroll = () => {
    if (window.scrollY > 400) btn.removeAttribute('hidden');
    else btn.setAttribute('hidden', '');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // état initial correct si la page est rouverte déjà scrollée
  btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
}
document.addEventListener('astro:page-load', initBackToTop);
if (document.readyState !== 'loading') initBackToTop();
else document.addEventListener('DOMContentLoaded', initBackToTop);
</script>
