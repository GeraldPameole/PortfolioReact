---
const NAV = [
  { href: '/',        label: 'Accueil' },
  { href: '/metiers', label: 'Métiers' },
  { href: '/blog',    label: 'Articles' },
  { href: '/skills',  label: 'Compétences' },
  { href: '/livres',  label: 'Livres' },
  { href: '/about',   label: 'À propos' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="Accueil">
      <span class="logo-bracket">&lt;</span>
      <span class="logo-name">GP</span>
      <span class="logo-bracket">/&gt;</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Navigation principale">
      {NAV.map(({ href, label }) => (
        <a
          href={href}
          class={`nav-link ${isActive(href) ? 'active' : ''}`}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Social + CTA -->
    <div class="header-actions">
      <a href="https://www.linkedin.com/in/geraldpameole/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
      </a>
      <a href="https://github.com/gpameole" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <a href="/cv" class="btn btn-outline-sm" aria-label="Voir le CV">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        CV
      </a>
      <a href="/contact" class="btn btn-primary btn-sm">Contact</a>

      <!-- Mobile toggle -->
      <button id="mobile-toggle" class="mobile-toggle" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu" hidden>
    <nav>
      {NAV.map(({ href, label }) => (
        <a href={href} class={`mobile-link ${isActive(href) ? 'active' : ''}`}>{label}</a>
      ))}
    </nav>
    <div class="mobile-socials">
      <a href="https://www.linkedin.com/in/geraldpameole/" target="_blank" rel="noopener noreferrer" class="social-link">LinkedIn</a>
      <a href="https://github.com/gpameole" target="_blank" rel="noopener noreferrer" class="social-link">GitHub</a>
    </div>
  </div>
</header>

<style>
  #site-header {
    padding: 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    background: rgba(5, 8, 22, 0.75);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: all 0.3s ease;
  }

  #site-header.scrolled .header-inner {
    background: rgba(5, 8, 22, 0.95);
    box-shadow: 0 4px 30px rgba(0,0,0,0.4);
  }

  /* Logo */
  .logo {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text-1);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.1em;
    white-space: nowrap;
    flex-shrink: 0;
    transition: filter 0.2s;
  }
  .logo:hover { filter: drop-shadow(0 0 8px var(--violet)); color: var(--text-1); }
  .logo-bracket { color: var(--violet); }
  .logo-name { color: var(--cyan); }

  /* Desktop nav */
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-3);
    text-decoration: none;
    padding: 0.45rem 0.85rem;
    border-radius: var(--r-full);
    transition: all 0.2s ease;
    letter-spacing: 0.01em;
    border: 1px solid transparent;
  }
  .nav-link:hover {
    color: var(--text-1);
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.08);
  }
  .nav-link.active {
    color: var(--violet-light);
    background: rgba(145,94,255,0.1);
    border-color: rgba(145,94,255,0.2);
  }

  /* Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .social-link {
    color: var(--text-3);
    display: flex;
    align-items: center;
    transition: color 0.2s;
    text-decoration: none;
    font-size: 0.85rem;
  }
  .social-link:hover { color: var(--text-1); }

  .btn-sm { padding: 0.5rem 1.2rem; font-size: 0.85rem; }
  .btn-outline-sm {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.45rem 1rem; font-size: 0.82rem; font-weight: 600;
    color: var(--text-2); border: 1px solid var(--border-bright);
    border-radius: var(--r-full); text-decoration: none;
    transition: all 0.2s; background: var(--glass);
    font-family: var(--font-sans);
  }
  .btn-outline-sm:hover { color: var(--text-1); border-color: var(--violet-light); background: rgba(145,94,255,0.08); }

  /* Mobile toggle */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: var(--glass);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    cursor: pointer;
    padding: 8px;
  }
  .mobile-toggle span {
    display: block;
    height: 1.5px;
    background: var(--text-2);
    border-radius: 2px;
    transition: all 0.3s ease;
  }
  .mobile-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .mobile-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .mobile-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* Mobile menu */
  .mobile-menu {
    background: rgba(5,8,22,0.97);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 1.5rem;
  }
  .mobile-menu nav { display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 1.5rem; }
  .mobile-link {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-2);
    text-decoration: none;
    padding: 0.75rem 1rem;
    border-radius: var(--r-md);
    transition: all 0.2s;
    border: 1px solid transparent;
  }
  .mobile-link:hover  { color: var(--text-1); background: var(--glass); }
  .mobile-link.active { color: var(--violet-light); background: rgba(145,94,255,0.1); border-color: rgba(145,94,255,0.2); }
  .mobile-socials { display: flex; gap: 1rem; padding-top: 1rem; border-top: 1px solid var(--border); }

  @media (max-width: 900px) {
    .nav-desktop    { display: none; }
    .mobile-toggle  { display: flex; }
    .header-actions .social-link { display: none; }
    .btn-sm { display: none; }
  }
</style>

<script is:inline>
  // Scrolled state
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (header) header.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  // Mobile menu
  const toggle = document.getElementById('mobile-toggle');
  const menu   = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', open ? 'false' : 'true');
      if (open) { menu.setAttribute('hidden', ''); } else { menu.removeAttribute('hidden'); }
    });
    // Close on link click
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.setAttribute('hidden', '');
    }));
  }
</script>
