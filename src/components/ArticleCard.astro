---
import type { CollectionEntry } from 'astro:content';
import { mapToStandardTheme, standardThemes } from '../utils/themeUtils';

interface Props {
  article: CollectionEntry<'articles'>;
}
const { article } = Astro.props;
const { title, description, publishDate, tags, domain } = article.data as any;

const themeKey  = mapToStandardTheme(domain || tags?.[0]);
const theme     = standardThemes[themeKey];
const slug      = article.slug;
const date      = new Date(publishDate).toLocaleDateString('fr-FR', { day:'numeric', month:'short', year:'numeric' });
const wordCount = article.body?.split(/\s+/).length ?? 0;
const readTime  = Math.max(1, Math.ceil(wordCount / 200));

// Domain → color accent
const DOMAIN_COLOR: Record<string, string> = {
  'gestion-projet':           'var(--cyan)',
  'developpement-web':        'var(--green)',
  'qualite-process':          '#c4b5fd',
  'formation':                '#fbbf24',
  'developpement-commercial': 'var(--orange)',
  'leadership-management':    'var(--violet-light)',
  'productivite-methodes':    'var(--cyan)',
  'marketing-communication':  '#f9a8d4',
  'innovation-technologies':  '#a78bfa',
  'transformation-digitale':  'var(--cyan)',
  'gestion-talents':          '#86efac',
  'service-client':           '#67e8f9',
  'gestion-connaissances':    '#fde68a',
  'outils-techniques':        '#94a3b8',
  'reconversion-carriere':    '#fca5a5',
};
const accent = DOMAIN_COLOR[domain] ?? 'var(--violet-light)';
---

<a href={`/blog/${slug}`} class="article-card">
  <div class="card-accent" style={`background:${accent}`}></div>
  <div class="card-body">
    <div class="card-meta">
      <span class="card-domain" style={`color:${accent}`}>
        {(domain ?? 'article').replace(/-/g,' ').replace(/\b\w/g,c=>c.toUpperCase())}
      </span>
      <span class="card-sep">·</span>
      <span class="card-time">{readTime} min</span>
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
    <div class="card-footer">
      <time class="card-date">{date}</time>
      <span class="card-arrow" style={`color:${accent}`}>→</span>
    </div>
  </div>
</a>

<style>
.article-card {
  display:flex;
  flex-direction:column;
  background:var(--bg-card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  text-decoration:none;
  overflow:hidden;
  transition:all .25s var(--ease-out);
  height:100%;
  position:relative;
}
.article-card:hover {
  background:var(--bg-card-hover);
  border-color:var(--border-bright);
  transform:translateY(-4px);
  box-shadow:0 12px 40px rgba(0,0,0,0.35);
}
.card-accent {
  height:3px;
  width:100%;
  flex-shrink:0;
  opacity:0.8;
  transition:opacity .25s;
}
.article-card:hover .card-accent { opacity:1; }
.card-body {
  padding:1.5rem;
  display:flex;
  flex-direction:column;
  gap:.75rem;
  flex:1;
}
.card-meta {
  display:flex;
  align-items:center;
  gap:.5rem;
  font-size:.75rem;
  font-family:var(--font-mono);
  letter-spacing:.04em;
}
.card-domain {
  font-weight:600;
  text-transform:uppercase;
  letter-spacing:.06em;
  font-size:.7rem;
}
.card-sep   { color:var(--text-4); }
.card-time  { color:var(--text-3); }
.card-title {
  font-family:var(--font-sans);
  font-size:1rem;
  font-weight:700;
  color:var(--text-1);
  line-height:1.4;
  letter-spacing:-.01em;
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}
.card-desc {
  font-size:.855rem;
  color:var(--text-3);
  line-height:1.7;
  display:-webkit-box;
  -webkit-line-clamp:3;
  -webkit-box-orient:vertical;
  overflow:hidden;
  flex:1;
}
.card-footer {
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding-top:.75rem;
  border-top:1px solid var(--border);
  margin-top:auto;
}
.card-date  { font-size:.75rem; color:var(--text-4); font-family:var(--font-mono); }
.card-arrow { font-size:1.05rem; transition:transform .2s; }
.article-card:hover .card-arrow { transform:translateX(4px); }
</style>
