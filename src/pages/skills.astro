---
import BaseLayout from '../layouts/BaseLayout.astro';

const SKILL_GROUPS = [
  {
    category: 'Gestion de Projet',
    icon: '🗂️',
    color: '#60a5fa',
    skills: [
      { name: 'Gestion de projet (PMP/Prince2)', level: 95 },
      { name: 'Méthodologies Agile & Scrum',     level: 92 },
      { name: 'Gestion des risques',             level: 88 },
      { name: 'Planification & Estimation',      level: 90 },
      { name: 'Gestion des parties prenantes',   level: 87 },
    ],
  },
  {
    category: 'Leadership & Management',
    icon: '🎯',
    color: '#a78bfa',
    skills: [
      { name: 'Management d\'équipe',            level: 93 },
      { name: 'Leadership situationnel',         level: 90 },
      { name: 'Conduite du changement (ADKAR)',  level: 88 },
      { name: 'Coaching & Mentoring',            level: 85 },
      { name: 'Communication & négociation',     level: 89 },
    ],
  },
  {
    category: 'Développement Web',
    icon: '💻',
    color: '#34d399',
    skills: [
      { name: 'React / Next.js / Astro',         level: 85 },
      { name: 'TypeScript / JavaScript',         level: 88 },
      { name: 'Node.js / REST API',              level: 80 },
      { name: 'Tailwind CSS / Design Systems',   level: 87 },
      { name: 'Git & CI/CD',                     level: 82 },
    ],
  },
  {
    category: 'Data & Analyse',
    icon: '📊',
    color: '#67e8f9',
    skills: [
      { name: 'KPIs & Tableaux de bord',         level: 91 },
      { name: 'Power BI / Data Studio',          level: 82 },
      { name: 'SQL & Analyse de données',        level: 78 },
      { name: 'Reporting & Pilotage',            level: 90 },
      { name: 'IA & Automatisation',             level: 75 },
    ],
  },
  {
    category: 'Formation & Pédagogie',
    icon: '🎓',
    color: '#fbbf24',
    skills: [
      { name: 'Ingénierie pédagogique',          level: 90 },
      { name: 'Animation de formations',         level: 92 },
      { name: 'E-learning & Digital Learning',   level: 82 },
      { name: 'Évaluation Kirkpatrick',          level: 85 },
      { name: 'Lean Management',                 level: 83 },
    ],
  },
  {
    category: 'Qualité & Process',
    icon: '✅',
    color: '#f9a8d4',
    skills: [
      { name: 'ISO 9001',                        level: 88 },
      { name: 'Lean / Six Sigma',                level: 83 },
      { name: 'Amélioration continue',           level: 87 },
      { name: 'Cartographie processus (BPMN)',   level: 80 },
      { name: 'Audit qualité',                   level: 82 },
    ],
  },
];

const TOOLS = [
  'Jira', 'Confluence', 'Trello', 'Notion', 'Figma',
  'VS Code', 'GitHub', 'Docker', 'Salesforce', 'HubSpot',
  'Power BI', 'Teams', 'Slack', 'Moodle', 'Articulate',
  'Zapier', 'Airtable', 'Linear', 'Webflow', 'Astro',
];

const CERTS = [
  { name: 'PMP — Project Management Professional', org: 'PMI', year: '2018', color: '#60a5fa' },
  { name: 'Prince2 Practitioner',                  org: 'Axelos', year: '2017', color: '#a78bfa' },
  { name: 'Lean Six Sigma Green Belt',              org: 'BSI', year: '2019', color: '#34d399' },
  { name: 'Scrum Master (CSM)',                     org: 'Scrum Alliance', year: '2020', color: '#fbbf24' },
  { name: 'ISO 9001 Lead Auditor',                  org: 'IRCA', year: '2021', color: '#f9a8d4' },
];
---

<BaseLayout title="Compétences" description="Compétences en gestion de projet, leadership, développement web, formation et qualité.">

  <div class="page-hero">
    <div class="orb orb-violet" style="width:500px;height:500px;top:-150px;right:-100px;opacity:0.3;"></div>
    <div class="container">
      <div style="text-align:center;position:relative;z-index:1">
        <span class="section-label reveal">Compétences</span>
        <h1 class="reveal reveal-delay-1" style="margin-top:1rem">
          Stack <span class="gradient-text">technique & métier</span>
        </h1>
        <p class="reveal reveal-delay-2" style="color:var(--text-3);font-size:1.05rem;max-width:500px;margin:1rem auto 0">
          15 ans de pratique terrain en management, développement et formation.
        </p>
      </div>
    </div>
  </div>

  <!-- Skill bars -->
  <section class="section">
    <div class="container">
      <div class="skills-grid">
        {SKILL_GROUPS.map((group, gi) => (
          <div class="skill-group glass-card reveal" style={`transition-delay:${gi*0.1}s`}>
            <div class="group-header">
              <span class="group-icon">{group.icon}</span>
              <h3 class="group-name" style={`color:${group.color}`}>{group.category}</h3>
            </div>
            <div class="skill-list">
              {group.skills.map(skill => (
                <div class="skill-item">
                  <div class="skill-row">
                    <span class="skill-name">{skill.name}</span>
                    <span class="skill-level" style={`color:${group.color}`}>{skill.level}%</span>
                  </div>
                  <div class="skill-bar-bg">
                    <div
                      class="skill-bar-fill"
                      style={`width:${skill.level}%;background:${group.color}`}
                      data-width={skill.level}
                    ></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="divider-glow container"></div>

  <!-- Tools -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label reveal">Outils</span>
        <h2 class="reveal reveal-delay-1">Écosystème <span class="gradient-text">quotidien</span></h2>
      </div>
      <div class="tools-grid reveal reveal-delay-2">
        {TOOLS.map(t => <span class="tool-tag">{t}</span>)}
      </div>
    </div>
  </section>

  <div class="divider-glow container"></div>

  <!-- Certifications -->
  <section class="section">
    <div class="container container-sm">
      <div class="section-header">
        <span class="section-label reveal">Certifications</span>
        <h2 class="reveal reveal-delay-1">Reconnaissances <span class="gradient-text">officielles</span></h2>
      </div>
      <div class="certs-list">
        {CERTS.map((c, i) => (
          <div class="cert-card glass-card reveal" style={`transition-delay:${i*0.1}s`}>
            <div class="cert-bar" style={`background:${c.color}`}></div>
            <div class="cert-body">
              <h4 class="cert-name">{c.name}</h4>
              <div class="cert-meta">
                <span class="cert-org" style={`color:${c.color}`}>{c.org}</span>
                <span class="cert-year">{c.year}</span>
              </div>
            </div>
            <div class="cert-badge" style={`background:rgba(255,255,255,0.04);border-color:${c.color}33`}>
              <span style={`color:${c.color}`}>✓</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-hero {
  position: relative;
  overflow: hidden;
  padding: 7rem 0 4rem;
  border-bottom: 1px solid var(--border);
}
.skills-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}
.skill-group { padding: 2rem; }
.group-header { display: flex; align-items: center; gap: .75rem; margin-bottom: 1.5rem; }
.group-icon { font-size: 1.6rem; }
.group-name { font-size: 1rem; font-weight: 700; font-family: var(--font-sans); margin: 0; }
.skill-list { display: flex; flex-direction: column; gap: 1rem; }
.skill-item { display: flex; flex-direction: column; gap: .4rem; }
.skill-row  { display: flex; justify-content: space-between; align-items: center; }
.skill-name { font-size: .875rem; color: var(--text-2); }
.skill-level { font-family: var(--font-mono); font-size: .78rem; font-weight: 600; }
.skill-bar-bg   { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
.skill-bar-fill { height: 100%; border-radius: 2px; width: 0; transition: width 1.2s var(--ease-out); }

.tools-grid {
  display: flex;
  flex-wrap: wrap;
  gap: .65rem;
}
.tool-tag {
  font-family: var(--font-mono);
  font-size: .8rem;
  padding: .4rem 1rem;
  background: var(--glass);
  border: 1px solid var(--border);
  border-radius: var(--r-full);
  color: var(--text-2);
  transition: all .2s;
}
.tool-tag:hover { border-color: var(--violet); color: var(--violet-light); background: rgba(145,94,255,.08); }

.certs-list { display: flex; flex-direction: column; gap: 1rem; }
.cert-card  { display: flex; align-items: center; gap: 0; overflow: hidden; padding: 0; }
.cert-bar   { width: 4px; height: 100%; min-height: 80px; align-self: stretch; flex-shrink: 0; }
.cert-body  { flex: 1; padding: 1.25rem 1.5rem; }
.cert-name  { font-size: .975rem; font-weight: 700; color: var(--text-1); margin-bottom: .4rem; font-family: var(--font-sans); }
.cert-meta  { display: flex; gap: 1rem; align-items: center; }
.cert-org   { font-size: .8rem; font-weight: 600; font-family: var(--font-mono); }
.cert-year  { font-size: .78rem; color: var(--text-4); font-family: var(--font-mono); }
.cert-badge {
  width: 44px; height: 44px;
  border-radius: 50%;
  border: 1px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 1.5rem;
  font-size: 1.1rem;
  flex-shrink: 0;
}

@media(max-width:900px) { .skills-grid { grid-template-columns: 1fr; } }
</style>

<script is:inline>
// Animate bars on scroll
if (typeof IntersectionObserver !== 'undefined') {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.skill-bar-fill').forEach(bar => {
          bar.style.width = bar.dataset.width + '%';
        });
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.skill-group').forEach(g => obs.observe(g));
}
</script>
