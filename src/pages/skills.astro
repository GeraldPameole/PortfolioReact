---

<BaseLayout title="Compétences" description="Compétences en gestion de projet, leadership, développement web, formation et qualité.">

  <div class="page-hero">
    <div class="orb orb-violet" style="width:500px;height:500px;top:-150px;right:-100px;opacity:0.3;"></div>
    <div class="container">
      <div style="text-align:center;position:relative;z-index:1">
        <span class="section-label reveal">Compétences</span>
        <h1 class="reveal reveal-delay-1" style="margin-top:1rem">
          Stack <span class="gradient-text">technique & métier</span>
        </h1>
        <p class="reveal reveal-delay-2" style="color:var(--text-3);font-size:1.05rem;max-width:500px;margin:1rem auto 0">
          20 ans de pratique terrain en management, développement et formation.
        </p>
      </div>
    </div>
  </div>

  <!-- Skill bars -->
  <section class="section">
    <div class="container">
      <div class="skills-grid">
        {SKILL_GROUPS.map((group, gi) => (
          <div class="skill-group glass-card reveal" style={`transition-delay:${gi*0.1}s`}>
            <div class="group-header">
              <span class="group-icon">{group.icon}</span>
              <h3 class="group-name" style={`color:${group.color}`}>{group.category}</h3>
            </div>
            <div class="skill-list">
              {group.skills.map(skill => (
                <div class="skill-item">
                  <div class="skill-row">
                    <span class="skill-name">{skill.name}</span>
                    <span class="skill-level" style={`color:${group.color}`}>{skill.level}%</span>
                  </div>
                  <div class="skill-bar-bg">
                    <div
                      class="skill-bar-fill"
                      style={`width:${skill.level}%;background:${group.color}`}
                      data-width={skill.level}
                    ></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="divider-glow container"></div>

  <!-- Tools -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label reveal">Outils</span>
        <h2 class="reveal reveal-delay-1">Écosystème <span class="gradient-text">quotidien</span></h2>
      </div>
      <div class="tool-groups">
        {TOOL_GROUPS.map((g, gi) => (
          <div class="tool-group reveal" style={`transition-delay:${gi*0.05}s`}>
            <h3 class="tool-group-label">{g.label}</h3>
            <div class="tools-grid">
              {g.items.map(t => <span class="tool-tag">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="divider-glow container"></div>

  <!-- Certifications -->
  <section class="section">
    <div class="container container-sm">
      <div class="section-header">
        <span class="section-label reveal">Diplômes & Certifications</span>
        <h2 class="reveal reveal-delay-1">Reconnaissances <span class="gradient-text">officielles</span></h2>
      </div>
      <div class="certs-list">
        {CERTS.map((c, i) => (
          <div class="cert-card glass-card reveal" style={`transition-delay:${i*0.1}s`}>
            <div class="cert-bar" style={`background:${c.color}`}></div>
            <div class="cert-body">
              <h4 class="cert-name">{c.name}</h4>
              <div class="cert-meta">
                <span class="cert-org" style={`color:${c.color}`}>{c.org}</span>
                <span class="cert-year">{c.year}</span>
              </div>
            </div>
            <div class="cert-badge" style={`background:rgba(255,255,255,0.04);border-color:${c.color}33`}>
              <span style={`color:${c.color}`}>✓</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-hero {
  position: relative;
  overflow: hidden;
  padding: 7rem 0 4rem;
  border-bottom: 1px solid var(--border);
}
.skills-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}
.skill-group { padding: 2rem; }
.group-header { display: flex; align-items: center; gap: .75rem; margin-bottom: 1.5rem; }
.group-icon { font-size: 1.6rem; }
.group-name { font-size: 1rem; font-weight: 700; font-family: var(--font-sans); margin: 0; }
.skill-list { display: flex; flex-direction: column; gap: 1rem; }
.skill-item { display: flex; flex-direction: column; gap: .4rem; }
.skill-row  { display: flex; justify-content: space-between; align-items: center; }
.skill-name { font-size: .875rem; color: var(--text-2); }
.skill-level { font-family: var(--font-mono); font-size: .78rem; font-weight: 600; }
.skill-bar-bg   { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
.skill-bar-fill { height: 100%; border-radius: 2px; width: 0; transition: width 1.2s var(--ease-out); }

.tool-groups {
  display: flex;
  flex-direction: column;
  gap: 1.75rem;
}
.tool-group {
  display: flex;
  flex-direction: column;
  gap: .85rem;
}
.tool-group-label {
  font-family: var(--font-mono);
  font-size: .78rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--text-3);
  margin: 0;
  padding-bottom: .35rem;
  border-bottom: 1px dashed var(--border);
}
.tools-grid {
  display: flex;
  flex-wrap: wrap;
  gap: .65rem;
}
.tool-tag {
  font-family: var(--font-mono);
  font-size: .8rem;
  padding: .4rem 1rem;
  background: var(--glass);
  border: 1px solid var(--border);
  border-radius: var(--r-full);
  color: var(--text-2);
  transition: all .2s;
}
.tool-tag:hover { border-color: var(--violet); color: var(--violet-light); background: rgba(145,94,255,.08); }

.certs-list { display: flex; flex-direction: column; gap: 1rem; }
.cert-card  { display: flex; align-items: center; gap: 0; overflow: hidden; padding: 0; }
.cert-bar   { width: 4px; height: 100%; min-height: 80px; align-self: stretch; flex-shrink: 0; }
.cert-body  { flex: 1; padding: 1.25rem 1.5rem; }
.cert-name  { font-size: .975rem; font-weight: 700; color: var(--text-1); margin-bottom: .4rem; font-family: var(--font-sans); }
.cert-meta  { display: flex; gap: 1rem; align-items: center; }
.cert-org   { font-size: .8rem; font-weight: 600; font-family: var(--font-mono); }
.cert-year  { font-size: .78rem; color: var(--text-4); font-family: var(--font-mono); }
.cert-badge {
  width: 44px; height: 44px;
  border-radius: 50%;
  border: 1px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 1.5rem;
  font-size: 1.1rem;
  flex-shrink: 0;
}

@media(max-width:900px) { .skills-grid { grid-template-columns: 1fr; } }
</style>

<script is:inline>
// Animate bars on scroll
if (typeof IntersectionObserver !== 'undefined') {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.skill-bar-fill').forEach(bar => {
          bar.style.width = bar.dataset.width + '%';
        });
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.skill-group').forEach(g => obs.observe(g));
}
</script>
