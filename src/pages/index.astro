---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allArticles = await getCollection('articles');
const recentArticles = allArticles
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 6);

const DOMAINS = [
  { name: 'Gestion de Projet',       icon: '🗂️', color: 'blue',   desc: 'Agile, Scrum, Prince2, risques et parties prenantes.' },
  { name: 'Leadership & Management', icon: '🎯', color: 'violet', desc: 'Management d\'équipe, performance, leadership situationnel.' },
  { name: 'Transformation Digitale', icon: '🚀', color: 'cyan',   desc: 'Conduite du changement, feuille de route, adoption des outils.' },
  { name: 'Formation',               icon: '🎓', color: 'green',  desc: 'Ingénierie pédagogique, e-learning, développement des compétences.' },
  { name: 'Développement Web',       icon: '💻', color: 'orange', desc: 'React, TypeScript, Astro, architecture applicative.' },
  { name: 'Qualité & Process',       icon: '✅', color: 'pink',   desc: 'ISO 9001, Lean, Six Sigma, optimisation des processus.' },
];

const SERVICES = [
  { title: 'Pilotage de projet',      desc: 'Cadrage, planning, suivi et livraison de projets complexes multi-acteurs.',              icon: '📋' },
  { title: 'Conseil en organisation', desc: 'Audit organisationnel, restructuration des processus et accompagnement au changement.',   icon: '🏗️' },
  { title: 'Formation & coaching',    desc: 'Programmes sur mesure, ateliers et coaching de managers en entreprise.',                  icon: '🎓' },
  { title: 'Développement web',       desc: 'Création d\'applications web modernes, performantes et accessibles.',                     icon: '💻' },
];

const colorMap: Record<string, { bg: string; border: string; text: string }> = {
  blue:   { bg:'rgba(59,130,246,0.08)',  border:'rgba(59,130,246,0.25)',  text:'#93c5fd' },
  violet: { bg:'rgba(145,94,255,0.08)',  border:'rgba(145,94,255,0.25)', text:'#c4b5fd' },
  cyan:   { bg:'rgba(0,207,253,0.07)',   border:'rgba(0,207,253,0.25)',  text:'#67e8f9' },
  green:  { bg:'rgba(34,197,94,0.07)',   border:'rgba(34,197,94,0.25)',  text:'#86efac' },
  orange: { bg:'rgba(249,115,22,0.08)',  border:'rgba(249,115,22,0.25)', text:'#fdba74' },
  pink:   { bg:'rgba(244,114,182,0.07)',border:'rgba(244,114,182,0.25)',text:'#f9a8d4' },
};
---

<BaseLayout title="Portfolio" description="Chef de projet & expert en transformation digitale — 15 ans d'expérience en télécom, management et développement web.">

  <Hero />

  <!-- DOMAINS -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label reveal">Expertise</span>
        <h2 class="reveal reveal-delay-1">Domaines de <span class="gradient-text">compétences</span></h2>
        <p class="section-sub reveal reveal-delay-2">6 domaines couvrant la gestion, le digital, la formation et le développement.</p>
      </div>
      <div class="domains-grid">
        {DOMAINS.map((d, i) => {
          const c = colorMap[d.color];
          return (
            <a href="/domaines" class="domain-card reveal" style={`transition-delay:${i*0.07}s`}>
              <div class="domain-icon" style={`background:${c.bg};border-color:${c.border}`}><span>{d.icon}</span></div>
              <h3 class="domain-name" style={`color:${c.text}`}>{d.name}</h3>
              <p class="domain-desc">{d.desc}</p>
              <span class="domain-arrow" style={`color:${c.text}`}>→</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <div class="divider-glow container"></div>

  <!-- SERVICES -->
  <section class="section">
    <div class="container">
      <div class="services-layout">
        <div class="services-left reveal">
          <span class="section-label">Services</span>
          <h2 style="margin-top:1rem">Ce que je<br/><span class="gradient-text">peux faire</span><br/>pour vous</h2>
          <p style="color:var(--text-3);margin-top:1.5rem;line-height:1.85">Que vous ayez besoin d'un chef de projet, d'un formateur ou d'un développeur — j'interviens sur l'ensemble de vos projets.</p>
          <a href="/contact" class="btn btn-primary" style="margin-top:2rem">Parlons de votre projet →</a>
        </div>
        <div class="services-right">
          {SERVICES.map((s, i) => (
            <div class="service-card glass-card reveal" style={`transition-delay:${i*0.1}s`}>
              <span class="service-icon">{s.icon}</span>
              <div><h4 class="service-title">{s.title}</h4><p class="service-desc">{s.desc}</p></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="divider-glow container"></div>

  <!-- ARTICLES -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label reveal">Contenu</span>
        <h2 class="reveal reveal-delay-1">Articles <span class="gradient-text">récents</span></h2>
        <p class="section-sub reveal reveal-delay-2">{allArticles.length} articles sur le management, la tech et la transformation digitale.</p>
      </div>
      <div class="articles-grid">
        {recentArticles.map((a, i) => (
          <div class="reveal" style={`transition-delay:${i*0.08}s`}><ArticleCard article={a} /></div>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem" class="reveal">
        <a href="/blog" class="btn btn-secondary">Voir tous les articles →</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-bottom:8rem">
    <div class="container">
      <div class="cta-card reveal">
        <div class="cta-orb" style="width:350px;height:350px;top:-100px;right:-80px;background:radial-gradient(circle,rgba(145,94,255,0.35),transparent 70%);filter:blur(70px);position:absolute;border-radius:50%;pointer-events:none;"></div>
        <div class="cta-orb" style="width:250px;height:250px;bottom:-60px;left:-40px;background:radial-gradient(circle,rgba(0,207,253,0.25),transparent 70%);filter:blur(60px);position:absolute;border-radius:50%;pointer-events:none;"></div>
        <div style="position:relative;z-index:1;text-align:center">
          <span class="section-label" style="display:inline-block;margin-bottom:1.5rem">Collaboration</span>
          <h2 style="font-size:clamp(1.8rem,3.5vw,2.8rem);margin-bottom:1rem">Prêt à <span class="gradient-text">travailler ensemble</span> ?</h2>
          <p style="color:var(--text-3);font-size:1.05rem;margin-bottom:2rem;max-width:460px;margin-left:auto;margin-right:auto">Discutons de votre projet, vos besoins, vos ambitions. Je réponds sous 24h.</p>
          <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
            <a href="/contact" class="btn btn-primary">Prendre contact</a>
            <a href="/projets" class="btn btn-ghost">Voir mes réalisations</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.section-sub { color:var(--text-3); max-width:500px; margin:.75rem auto 0; font-size:1rem; }

.domains-grid {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:1.25rem;
}
.domain-card {
  background:var(--bg-card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:1.75rem;
  text-decoration:none;
  display:flex;
  flex-direction:column;
  gap:.75rem;
  transition:all .25s var(--ease-out);
  position:relative;
  overflow:hidden;
}
.domain-card:hover { transform:translateY(-4px); border-color:var(--border-bright); background:var(--bg-card-hover); }
.domain-icon {
  width:50px; height:50px;
  border-radius:var(--r-md);
  border:1px solid;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:1.4rem;
}
.domain-name { font-size:.975rem; font-weight:700; font-family:var(--font-sans); margin:0; }
.domain-desc { font-size:.85rem; color:var(--text-3); line-height:1.65; flex:1; }
.domain-arrow { font-size:1.1rem; align-self:flex-end; transition:transform .2s; }
.domain-card:hover .domain-arrow { transform:translateX(4px); }

.services-layout { display:grid; grid-template-columns:1fr 1.4fr; gap:5rem; align-items:center; }
.services-right { display:flex; flex-direction:column; gap:1rem; }
.service-card { display:flex; align-items:flex-start; gap:1.25rem; padding:1.4rem; }
.service-icon { font-size:1.6rem; flex-shrink:0; }
.service-title { font-size:.975rem; font-weight:700; color:var(--text-1); margin-bottom:.35rem; font-family:var(--font-sans); }
.service-desc  { font-size:.855rem; color:var(--text-3); line-height:1.65; }

.articles-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.25rem; }

.cta-card {
  background:var(--bg-1);
  border:1px solid var(--border-bright);
  border-radius:var(--r-xl);
  padding:5rem 3rem;
  position:relative;
  overflow:hidden;
  box-shadow:0 0 0 1px rgba(145,94,255,.1), 0 20px 80px rgba(145,94,255,.1);
}

@media(max-width:1024px) {
  .domains-grid { grid-template-columns:repeat(2,1fr); }
  .articles-grid { grid-template-columns:repeat(2,1fr); }
  .services-layout { grid-template-columns:1fr; gap:3rem; }
}
@media(max-width:640px) {
  .domains-grid { grid-template-columns:1fr; }
  .articles-grid { grid-template-columns:1fr; }
  .cta-card { padding:3rem 1.5rem; }
}
</style>
