---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const works = await getCollection('work');
const sorted = works.sort((a, b) =>
  new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

// Category â color (alignÃĐ sur src/config/domains.ts)
const CAT_COLOR: Record<string, { label: string; color: string; icon: string }> = {
  management:              { label: 'Gestion de projet', color: '#60a5fa', icon: 'ðïļ' },
  'developpement-web':     { label: 'DÃĐveloppement Web', color: '#34d399', icon: 'ðŧ' },
  business:                { label: 'DÃĐveloppement commercial', color: '#fb923c', icon: 'ðĪ' },
  'qualite-process':       { label: 'QualitÃĐ & Process', color: '#a78bfa', icon: 'â' },
  'developpement-personnel':{ label: 'Formation',        color: '#fbbf24', icon: 'ð' },
};

// Mapping explicite frontmatter.domain â catÃĐgorie
const DOMAIN_TO_CAT: Record<string, string> = {
  'gestion-projet':           'management',
  'developpement-web':        'developpement-web',
  'developpement-commercial': 'business',
  'qualite-process':          'qualite-process',
  'formation':                'developpement-personnel',
};

function getCategory(project: any) {
  // 1. Le frontmatter `domain` prime â explicite > heuristique
  const declaredDomain = project.data.domain;
  if (declaredDomain && DOMAIN_TO_CAT[declaredDomain]) return DOMAIN_TO_CAT[declaredDomain];

  // 2. Heuristique sur les tags uniquement (la description peut mentionner
  //    "formation" comme levier d'un autre mÃĐtier â cf. superviseur commercial)
  const tags: string[] = (project.data.tags ?? []).map((t: string) => t.toLowerCase());
  const tagStr = tags.join(' ');

  if (/(commercial|business|vente|sales|fidÃĐlis)/.test(tagStr)) return 'business';
  if (/(web|react|next|typescript|node|front|back|seo|rgpd)/.test(tagStr)) return 'developpement-web';
  if (/(qualit|process|lean|iso|mÃĐthodes)/.test(tagStr)) return 'qualite-process';
  if (/(form|coach|train|pÃĐdagog|offshore)/.test(tagStr)) return 'developpement-personnel';
  return 'management';
}
---

<BaseLayout title="Projets & ExpÃĐriences" description="20 ans d'expÃĐrience en gestion de projet, dÃĐveloppement web, management et formation.">

  <!-- Hero -->
  <div class="page-hero">
    <div class="orb orb-violet" style="width:500px;height:500px;top:-150px;left:-100px;opacity:0.3;"></div>
    <div class="orb orb-cyan"   style="width:350px;height:350px;bottom:-80px;right:-80px;opacity:0.2;"></div>
    <div class="container">
      <div style="text-align:center;position:relative;z-index:1">
        <span class="section-label reveal">ExpÃĐriences</span>
        <h1 class="reveal reveal-delay-1" style="margin-top:1rem">
          Projets &amp; <span class="gradient-text">rÃĐalisations</span>
        </h1>
        <p class="reveal reveal-delay-2" style="color:var(--text-3);font-size:1.05rem;max-width:540px;margin:1.25rem auto 0;line-height:1.8">
          20 ans de terrain â gestion de projet tÃĐlÃĐcom, dÃĐveloppement web, management d'ÃĐquipes et formation professionnelle.
        </p>
      </div>
    </div>
  </div>

  <!-- Timeline grid -->
  <section class="section">
    <div class="container">
      <div class="projects-grid">
        {sorted.map((project, i) => {
          const cat   = getCategory(project);
          const meta  = CAT_COLOR[cat] ?? CAT_COLOR.management;
          const techs = project.data.technologies ?? [];
          const date  = new Date(project.data.publishDate).toLocaleDateString('fr-FR', { month: 'short', year: 'numeric' });

          return (
            <a href={`/projets/${project.slug}`} class="project-card reveal" style={`transition-delay:${Math.min(i,5)*0.09}s`}>
              <!-- Top accent -->
              <div class="card-top" style={`background:linear-gradient(90deg,${meta.color}25,transparent)`}>
                <div class="card-cat">
                  <span class="cat-icon">{meta.icon}</span>
                  <span class="cat-label" style={`color:${meta.color}`}>{meta.label}</span>
                </div>
                <span class="card-date" style={`color:${meta.color}`}>{date}</span>
              </div>

              <!-- Image -->
              {project.data.img && (
                <div class="card-image">
                  {project.data.img.endsWith('.svg') ? (
                    <object
                      data={project.data.img}
                      type="image/svg+xml"
                      aria-label={project.data.img_alt ?? project.data.title}
                      width="800"
                      height="500"
                    >
                      <img src={project.data.img} alt={project.data.img_alt ?? project.data.title} loading="lazy" width="800" height="500" />
                    </object>
                  ) : (
                    <img src={project.data.img} alt={project.data.img_alt ?? project.data.title} loading="lazy" />
                  )}
                  <div class="image-overlay" style={`background:linear-gradient(to top,${meta.color}20,transparent)`}></div>
                </div>
              )}

              <!-- Body -->
              <div class="card-body">
                {project.data.company && (
                  <p class="card-company" style={`color:${meta.color}`}>{project.data.company}</p>
                )}
                <h3 class="card-title">{project.data.title}</h3>
                <p class="card-desc">{project.data.description}</p>

                {project.data.period && (
                  <div class="card-period">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {project.data.period}
                  </div>
                )}

                {techs.length > 0 && (
                  <div class="card-techs">
                    {techs.slice(0, 4).map((t: string) => (
                      <span class="tech" style={`border-color:${meta.color}35;color:${meta.color}`}>{t}</span>
                    ))}
                    {techs.length > 4 && <span class="tech-more" style={`color:${meta.color}`}>+{techs.length - 4}</span>}
                  </div>
                )}
              </div>

              <div class="card-footer" style={`border-color:${meta.color}25`}>
                <span class="card-cta" style={`color:${meta.color}`}>Voir le dÃĐtail â</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-hero {
  position: relative;
  overflow: hidden;
  padding: 7rem 0 4.5rem;
  border-bottom: 1px solid var(--border);
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.project-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  overflow: hidden;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  transition: all .25s var(--ease-out);
}
.project-card:hover {
  background: var(--bg-card-hover);
  border-color: var(--border-bright);
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: .85rem 1.25rem;
  border-bottom: 1px solid var(--border);
}
.card-cat   { display: flex; align-items: center; gap: .5rem; }
.cat-icon   { font-size: 1rem; }
.cat-label  { font-size: .75rem; font-weight: 700; font-family: var(--font-sans); letter-spacing: .04em; text-transform: uppercase; }
.card-date  { font-family: var(--font-mono); font-size: .75rem; }

.card-image {
  height: 160px;
  overflow: hidden;
  position: relative;
}
.card-image img,
.card-image object { width: 100%; height: 100%; object-fit: cover; transition: transform .4s var(--ease-out); display: block; }
.project-card:hover .card-image img,
.project-card:hover .card-image object { transform: scale(1.04); }
.image-overlay { position: absolute; inset: 0; }

.card-body { padding: 1.25rem; display: flex; flex-direction: column; gap: .6rem; flex: 1; }
.card-company { font-family: var(--font-mono); font-size: .75rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; }
.card-title   { font-family: var(--font-sans); font-size: 1rem; font-weight: 700; color: var(--text-1); line-height: 1.35; }
.card-desc    { font-size: .855rem; color: var(--text-3); line-height: 1.65; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.card-period  { display: flex; align-items: center; gap: .4rem; font-size: .78rem; color: var(--text-4); font-family: var(--font-mono); }
.card-period svg { flex-shrink: 0; }

.card-techs { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: .25rem; }
.tech {
  font-size: .7rem;
  padding: .2rem .6rem;
  border-radius: var(--r-full);
  border: 1px solid;
  font-family: var(--font-mono);
  font-weight: 500;
}
.tech-more { font-size: .7rem; color: var(--text-4); font-family: var(--font-mono); align-self: center; }

.card-footer {
  padding: .85rem 1.25rem;
  border-top: 1px solid;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
.card-cta {
  font-family: var(--font-mono);
  font-size: .8rem;
  font-weight: 600;
  transition: transform .2s;
}
.project-card:hover .card-cta { transform: translateX(3px); }

@media(max-width:1024px) { .projects-grid { grid-template-columns: repeat(2, 1fr); } }
@media(max-width:640px)  { .projects-grid { grid-template-columns: 1fr; } }
</style>
