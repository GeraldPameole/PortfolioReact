---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleProgressBar from '../../components/ArticleProgressBar.astro';
import BackToTop from '../../components/BackToTop.astro';
import { calculateReadingTime, mapToStandardTheme } from '../../utils/themeUtils';

export async function getStaticPaths() {
  const all = await getCollection('articles');
  const sorted = all.sort(
    (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
  );
  return sorted.map((article, idx) => ({
    params: { slug: article.slug },
    props: {
      article,
      prev: idx < sorted.length - 1 ? sorted[idx + 1] : null,
      next: idx > 0                  ? sorted[idx - 1] : null,
    },
  }));
}

const { article, prev, next } = Astro.props;
const { Content } = await article.render();

const domain     = (article.data as any).domain ?? '';
const tags       = article.data.tags ?? [];
const readTime   = calculateReadingTime(article.body ?? '');
const date       = new Date(article.data.publishDate).toLocaleDateString('fr-FR', {
  year: 'numeric', month: 'long', day: 'numeric',
// @ts-ignore
  timeZone: 'Europe/Paris',
});
const themeKey   = mapToStandardTheme(domain || tags[0]);

// Related: same domain, exclude current, max 3
const allArticles   = await getCollection('articles');
const related = allArticles
  .filter(a => a.slug !== article.slug && (a.data as any).domain === domain)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3);

// Domain accent color
const DOMAIN_COLOR: Record<string, string> = {
  'gestion-projet':           'var(--cyan)',
  'developpement-web':        '#34d399',
  'qualite-process':          '#c4b5fd',
  'formation':                '#fbbf24',
  'developpement-commercial': '#fb923c',
  'leadership-management':    'var(--violet-light)',
  'productivite-methodes':    'var(--cyan)',
  'marketing-communication':  '#f9a8d4',
  'innovation-technologies':  '#a78bfa',
  'transformation-digitale':  '#22d3ee',
  'gestion-talents':          '#86efac',
  'service-client':           '#67e8f9',
  'gestion-connaissances':    '#fde68a',
  'outils-techniques':        '#94a3b8',
  'reconversion-carriere':    '#fca5a5',
};
const accent   = DOMAIN_COLOR[domain] ?? 'var(--violet-light)';
const domLabel = domain.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());

// Article image for og:image
const ogImage = (article.data as any).image
  ?? `/assets/articles/${article.slug.split('/').pop()}.jpg`
  ?? '/placeholder-article.webp';

// JSON-LD Article schema
const canonicalUrl = `https://geraldpameole.fr/blog/${article.slug}`;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.data.title,
  "description": article.data.description,
  "datePublished": article.data.publishDate,
  "author": { "@type": "Person", "name": "Gérald Paméole", "url": "https://geraldpameole.fr" },
  "publisher": { "@type": "Person", "name": "Gérald Paméole" },
  "url": canonicalUrl,
  "keywords": (tags as string[]).join(', '),
  "articleSection": domLabel,
  "timeRequired": `PT${readTime}M`,
};

// Social share URLs
const encodedUrl   = encodeURIComponent(canonicalUrl);
const encodedTitle = encodeURIComponent(article.data.title);
const shareLinkedIn = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
const shareTwitter  = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const shareEmail    = `mailto:?subject=${encodedTitle}&body=${encodedUrl}`;
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  image={ogImage}
  type="article"
  keywords={(tags as string[]).join(', ')}
  jsonLd={articleSchema}
>
  <ArticleProgressBar />

  <!-- Hero -->
  <div class="article-hero">
    <div class="orb orb-violet" style="width:350px;height:350px;top:-100px;right:-80px;opacity:0.2;"></div>
    <div class="container hero-inner">
      <a href="/blog" class="back-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
        Tous les articles
      </a>

      <div class="hero-badges">
        {domain && (
          <span class="domain-badge" style={`color:${accent};background:${accent}12;border-color:${accent}30`}>
            {domLabel}
          </span>
        )}
        <span class="meta-item">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {readTime} min de lecture
        </span>
        <time class="meta-item">{date}</time>
      </div>

      <h1 class="hero-title">{article.data.title}</h1>
      {article.data.description && (
        <p class="hero-desc">{article.data.description}</p>
      )}

      {tags.length > 0 && (
        <div class="tag-list">
          {(tags as string[]).map(t => (
            <span class="tag" style={`border-color:${accent}30;color:${accent}`}>#{t}</span>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Article layout -->
  <div class="article-body">
    <div class="container article-layout">

      <!-- Mobile ToC (details/summary, hidden on desktop) -->
      <details class="mobile-toc" id="mobile-toc-details">
        <summary class="mobile-toc-summary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>
          Dans cet article
          <svg class="chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <nav id="mobile-toc-nav" class="mobile-toc-nav"></nav>
      </details>

      <!-- Main content -->
      <article class="prose-article">
        <Content />
      </article>

      <!-- Sticky sidebar -->
      <aside class="article-sidebar">

        <!-- Table of contents (built client-side from H2s) -->
        <div class="sidebar-card toc-card" id="toc-card" hidden>
          <p class="sidebar-label">Dans cet article</p>
          <nav id="toc-nav" aria-label="Table des matières"></nav>
        </div>

        <!-- Share buttons -->
        <div class="sidebar-card share-card">
          <p class="sidebar-label">Partager</p>
          <div class="share-btns">
            <a href={shareLinkedIn} target="_blank" rel="noopener noreferrer" class="share-btn share-li" aria-label="Partager sur LinkedIn">
              <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              LinkedIn
            </a>
            <a href={shareTwitter} target="_blank" rel="noopener noreferrer" class="share-btn share-tw" aria-label="Partager sur X">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              X
            </a>
            <a href={shareEmail} class="share-btn share-em" aria-label="Partager par email">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              Email
            </a>
          </div>
        </div>

        <!-- Quick meta -->
        <div class="sidebar-card">
          <p class="sidebar-label">À propos de cet article</p>
          <div class="sidebar-meta-row">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{readTime} min de lecture</span>
          </div>
          <div class="sidebar-meta-row">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>{date}</span>
          </div>
          {domain && (
            <div class="sidebar-meta-row">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              <span style={`color:${accent}`}>{domLabel}</span>
            </div>
          )}
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="sidebar-card">
            <p class="sidebar-label">Tags</p>
            <div class="tag-list" style="gap:.35rem">
              {(tags as string[]).map(t => (
                <span class="tag" style={`border-color:${accent}30;color:${accent}`}>#{t}</span>
              ))}
            </div>
          </div>
        )}

        <!-- CTA -->
        <div class="sidebar-card" style={`border-color:${accent}25`}>
          <p class="sidebar-label">Un projet similaire ?</p>
          <p style="font-size:.85rem;color:var(--text-3);line-height:1.7;margin-bottom:1.25rem">
            Discutons de vos enjeux — je réponds sous 24h.
          </p>
          <a href="/contact" class="btn btn-primary" style="width:100%;justify-content:center;font-size:.875rem">
            Me contacter →
          </a>
        </div>

      </aside>
    </div>
  </div>

  <!-- ── Related articles ────────────────────────────────────────────────── -->
  {related.length > 0 && (
    <section class="section" style="padding-top:0;border-top:1px solid var(--border)">
      <div class="container">
        <div class="section-header" style="margin-bottom:2rem">
          <span class="section-label">Sur le même domaine</span>
          <h2 style="font-size:1.5rem;margin:.5rem 0 0">
            Articles <span class="gradient-text">liés</span>
          </h2>
        </div>
        <div class="related-grid">
          {related.map(r => {
            const rDomain  = (r.data as any).domain ?? '';
            const rAccent  = DOMAIN_COLOR[rDomain] ?? 'var(--violet-light)';
            const rDate    = new Date(r.data.publishDate).toLocaleDateString('fr-FR', { month: 'short', year: 'numeric' });
            const rRead    = Math.max(1, Math.ceil((r.body ?? '').split(/\s+/).length / 200));
            return (
              <a href={`/blog/${r.slug}`} class="related-card reveal">
                <div class="rc-accent" style={`background:${rAccent}`}></div>
                <div class="rc-body">
                  <div class="rc-meta">
                    <span style={`color:${rAccent};font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;font-family:var(--font-mono)`}>
                      {rDomain.replace(/-/g,' ').replace(/\b\w/g,(c:string)=>c.toUpperCase())}
                    </span>
                    <span style="color:var(--text-4);font-size:.72rem;font-family:var(--font-mono)">{rRead} min · {rDate}</span>
                  </div>
                  <h3 class="rc-title">{r.data.title}</h3>
                  <p class="rc-desc">{r.data.description}</p>
                  <span class="rc-cta" style={`color:${rAccent}`}>Lire l'article →</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ── Prev / Next navigation ─────────────────────────────────────────── -->
  <nav class="article-nav" aria-label="Navigation entre articles">
    <div class="container nav-inner">
      {prev ? (
        <a href={`/blog/${prev.slug}`} class="nav-card nav-prev">
          <span class="nav-dir">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
            Article précédent
          </span>
          <span class="nav-title">{prev.data.title}</span>
          <span class="nav-domain">{((prev.data as any).domain ?? '').replace(/-/g,' ').replace(/\b\w/g,(c:string)=>c.toUpperCase())}</span>
        </a>
      ) : <div/>}

      {next ? (
        <a href={`/blog/${next.slug}`} class="nav-card nav-next">
          <span class="nav-dir">
            Article suivant
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </span>
          <span class="nav-title">{next.data.title}</span>
          <span class="nav-domain">{((next.data as any).domain ?? '').replace(/-/g,' ').replace(/\b\w/g,(c:string)=>c.toUpperCase())}</span>
        </a>
      ) : <div/>}
    </div>
  </nav>

  <BackToTop />
</BaseLayout>

<style>
/* ── Share buttons ──────────────────────────────────────────────────────── */
.share-card { padding: 1.1rem 1.35rem; }
.share-btns { display: flex; gap: .5rem; flex-wrap: wrap; }
.share-btn {
  display: inline-flex; align-items: center; gap: .4rem;
  font-family: var(--font-mono); font-size: .75rem; font-weight: 600;
  padding: .35rem .85rem; border-radius: var(--r-full);
  text-decoration: none; border: 1px solid; transition: all .2s;
}
.share-li { color: #0a66c2; border-color: rgba(10,102,194,.35); background: rgba(10,102,194,.08); }
.share-li:hover { background: rgba(10,102,194,.18); }
.share-tw { color: var(--text-2); border-color: var(--border); background: var(--glass); }
.share-tw:hover { border-color: var(--border-bright); }
.share-em { color: var(--violet-light); border-color: rgba(145,94,255,.3); background: rgba(145,94,255,.08); }
.share-em:hover { background: rgba(145,94,255,.16); }

/* ── Print ──────────────────────────────────────────────────────────────── */
@media print {
  body { background: #fff !important; color: #111 !important; }
  #site-header, #back-to-top, .article-sidebar, .article-nav,
  .related-grid, #read-progress, .back-link { display: none !important; }
  .article-layout { grid-template-columns: 1fr !important; }
  .prose-article :global(a)::after { content: ' (' attr(href) ')'; font-size: .8em; color: #666; }
  .prose-article { max-width: 100% !important; }
}

/* ── Hero ──────────────────────────────────────────────────────────────── */
.article-hero {
  position: relative;
  overflow: hidden;
  border-bottom: 1px solid var(--border);
  padding-bottom: 3.5rem;
}
.hero-inner {
  position: relative;
  z-index: 1;
  padding-top: 6.5rem;
  max-width: 820px;
}
.back-link {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  color: var(--text-3);
  font-family: var(--font-mono);
  font-size: .82rem;
  text-decoration: none;
  margin-bottom: 2rem;
  transition: color .2s;
}
.back-link:hover { color: var(--text-1); }

.hero-badges {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: .6rem;
  margin-bottom: 1.25rem;
}
.domain-badge {
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: .25rem .85rem;
  border-radius: var(--r-full);
  border: 1px solid;
  font-family: var(--font-sans);
}
.meta-item {
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  font-family: var(--font-mono);
  font-size: .78rem;
  color: var(--text-3);
}
.hero-title {
  font-size: clamp(1.7rem, 4vw, 3rem);
  color: var(--text-1);
  line-height: 1.2;
  margin: 0 0 1.1rem;
  letter-spacing: -.02em;
}
.hero-desc {
  font-size: 1.08rem;
  color: var(--text-3);
  line-height: 1.8;
  max-width: 680px;
  margin: 0 0 1.5rem;
}
.tag-list { display: flex; flex-wrap: wrap; gap: .4rem; }
.tag {
  font-size: .72rem;
  font-family: var(--font-mono);
  font-weight: 500;
  padding: .22rem .65rem;
  border-radius: var(--r-full);
  border: 1px solid;
}

/* ── Layout ────────────────────────────────────────────────────────────── */
.article-body { padding: 3.5rem 0 5rem; }
.article-layout {
  display: grid;
  grid-template-columns: 1fr 260px;
  gap: 4rem;
  align-items: flex-start;
}

/* ── Prose ─────────────────────────────────────────────────────────────── */
.prose-article { min-width: 0; }
.prose-article :global(h1) { display: none; }
.prose-article :global(h2) {
  font-size: 1.45rem;
  color: var(--text-1);
  font-family: var(--font-sans);
  font-weight: 700;
  margin: 3rem 0 .85rem;
  padding-bottom: .6rem;
  border-bottom: 1px solid var(--border);
}
.prose-article :global(h3) {
  font-size: 1.15rem;
  color: var(--violet-light);
  font-family: var(--font-sans);
  font-weight: 700;
  margin: 2.2rem 0 .6rem;
}
.prose-article :global(h4) { color: var(--text-2); font-size: 1rem; margin: 1.5rem 0 .4rem; }
.prose-article :global(p)  { color: var(--text-2); line-height: 1.9; margin-bottom: 1.2rem; font-size: .975rem; }
.prose-article :global(ul),
.prose-article :global(ol) { color: var(--text-2); margin-bottom: 1.2rem; padding-left: 1.6rem; }
.prose-article :global(li) { margin-bottom: .5rem; line-height: 1.75; }
.prose-article :global(strong) { color: var(--text-1); font-weight: 600; }
.prose-article :global(em)     { color: var(--cyan-light); font-style: italic; }
.prose-article :global(a)      { color: var(--violet-light); text-decoration: underline; text-underline-offset: 3px; }
.prose-article :global(a:hover){ color: var(--violet); }
.prose-article :global(blockquote) {
  border-left: 3px solid var(--violet);
  padding: .85rem 1.5rem;
  margin: 1.75rem 0;
  background: rgba(145,94,255,0.06);
  border-radius: 0 var(--r-md) var(--r-md) 0;
  color: var(--text-3);
  font-style: italic;
}
.prose-article :global(code) {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  padding: .15em .5em;
  font-size: .88em;
  color: var(--cyan);
  font-family: var(--font-mono);
}
.prose-article :global(pre) {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 1.25rem 1.5rem;
  overflow-x: auto;
  margin: 1.5rem 0;
}
.prose-article :global(pre code) {
  background: none;
  border: none;
  padding: 0;
  font-size: .875rem;
  color: var(--text-2);
}
.prose-article :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin: 1.75rem 0;
  font-size: .88rem;
}
.prose-article :global(th) {
  background: var(--bg-2);
  color: var(--text-1);
  padding: .7rem 1rem;
  text-align: left;
  font-weight: 700;
  border-bottom: 1px solid var(--border-bright);
  font-family: var(--font-sans);
}
.prose-article :global(td) {
  padding: .7rem 1rem;
  border-bottom: 1px solid var(--border);
  color: var(--text-2);
}
.prose-article :global(tr:last-child td) { border-bottom: none; }
.prose-article :global(img) {
  width: 100%;
  border-radius: var(--r-lg);
  margin: 1.5rem 0;
  border: 1px solid var(--border);
}
.prose-article :global(hr) {
  border: none;
  border-top: 1px solid var(--border);
  margin: 2.5rem 0;
}

/* ── Sidebar ────────────────────────────────────────────────────────────── */
.article-sidebar { position: sticky; top: 6rem; display: flex; flex-direction: column; gap: 1.25rem; }
.sidebar-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 1.35rem;
}
.sidebar-label {
  font-family: var(--font-sans);
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: .85rem;
}
.sidebar-meta-row {
  display: flex;
  align-items: center;
  gap: .5rem;
  font-size: .83rem;
  color: var(--text-3);
  margin-bottom: .6rem;
  font-family: var(--font-mono);
}
.sidebar-meta-row svg { color: var(--text-4); flex-shrink: 0; }

/* ── Related articles ───────────────────────────────────────────────────── */
.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}
.related-card {
  display: flex;
  flex-direction: column;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  overflow: hidden;
  text-decoration: none;
  transition: all .25s var(--ease-out);
}
.related-card:hover {
  background: var(--bg-card-hover);
  border-color: var(--border-bright);
  transform: translateY(-3px);
  box-shadow: var(--shadow-md);
}
.rc-accent { height: 3px; flex-shrink: 0; opacity: .85; }
.rc-body   { padding: 1.1rem 1.25rem; display: flex; flex-direction: column; gap: .55rem; flex: 1; }
.rc-meta   { display: flex; align-items: center; justify-content: space-between; gap: .5rem; }
.rc-title  {
  font-family: var(--font-sans);
  font-size: .95rem;
