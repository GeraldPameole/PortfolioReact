/* ── Table of contents ──────────────────────────────────────────────────── */
.toc-card { padding: 1.1rem 1.35rem; }
#toc-nav { display: flex; flex-direction: column; gap: .15rem; }
.toc-link {
  display: block;
  font-size: .8rem;
  color: var(--text-3);
  text-decoration: none;
  padding: .28rem .5rem;
  border-radius: var(--r-sm);
  border-left: 2px solid transparent;
  transition: all .18s;
  line-height: 1.4;
  font-family: var(--font-sans);
}
.toc-link:hover { color: var(--text-1); background: var(--glass); }
.toc-link.active {
  color: var(--violet-light);
  border-left-color: var(--violet);
  background: rgba(145,94,255,.06);
}
.toc-link.h3 { padding-left: 1.1rem; font-size: .76rem; }
</style>

<script>
// Table of contents — desktop sidebar + mobile <details>
(function buildToc() {
  const card      = document.getElementById('toc-card');
  const nav       = document.getElementById('toc-nav');
  const mobileNav = document.getElementById('mobile-toc-nav');
  const mobileDet = document.getElementById('mobile-toc-details');
  const article   = document.querySelector('.prose-article');
  if (!article) return;

  const headings = Array.from(article.querySelectorAll('h2, h3'))
    .filter(h => h.textContent?.trim());

  if (headings.length < 2) return;

  // Ensure IDs
  headings.forEach(h => {
    if (!h.id) {
      h.id = (h.textContent ?? '')
        .trim()
        .toLowerCase()
        .normalize('NFD').replace(/[̀-ͯ]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '');
    }
  });

  function makeLink(h: Element, container: Element) {
    const a = document.createElement('a');
    a.href = '#' + (h as HTMLElement).id;
    a.textContent = h.textContent?.trim() ?? '';
    a.className = 'toc-link' + (h.tagName === 'H3' ? ' h3' : '');
    a.addEventListener('click', e => {
      e.preventDefault();
      (h as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (mobileDet) (mobileDet as HTMLDetailsElement).open = false;
    });
    container.appendChild(a);
  }

  // Desktop
  if (nav && card) {
    headings.forEach(h => makeLink(h, nav));
    card.hidden = false;
  }

  // Mobile
  if (mobileNav) {
    headings.forEach(h => makeLink(h, mobileNav));
  }

  // Active highlight on scroll (desktop only)
  if (nav) {
    const links = Array.from(nav.querySelectorAll('.toc-link'));
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          links.forEach(l => l.classList.remove('active'));
          const active = links.find(l => l.getAttribute('href') === '#' + (entry.target as HTMLElement).id);
          if (active) active.classList.add('active');
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });
    headings.forEach(h => observer.observe(h));
  }
})();
</script>
