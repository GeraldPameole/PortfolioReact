---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const articles = await getCollection('articles');
const sorted   = articles.sort((a, b) =>
  new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

const DOMAINS = [...new Set(articles.map((a: any) => a.data.domain).filter(Boolean))].sort() as string[];
---

<BaseLayout title="Articles" description={`${articles.length} articles sur le management, la transformation digitale, le développement web et la formation.`}>
  <div class="page-hero">
    <div class="orb orb-violet" style="width:500px;height:500px;top:-150px;left:-100px;opacity:0.3;"></div>
    <div class="container">
      <div class="hero-inner">
        <span class="section-label reveal">Blog</span>
        <h1 class="reveal reveal-delay-1">
          <span class="gradient-text">{articles.length} articles</span><br/>
          sur l'expertise métier
        </h1>
        <p class="hero-sub reveal reveal-delay-2">Management, transformation digitale, développement web, formation et productivité.</p>
      </div>
    </div>
  </div>

  <div class="container section">
    <!-- Domain filters -->
    <div class="filters reveal">
      <button class="filter-btn active" data-filter="all">Tous ({articles.length})</button>
      {DOMAINS.map(d => (
        <button class="filter-btn" data-filter={d}>
          {d.replace(/-/g,' ').replace(/\b\w/g,c=>c.toUpperCase())}
        </button>
      ))}
    </div>

    <!-- Grid -->
    <div class="articles-grid" id="articles-grid">
      {sorted.map((a, i) => (
        <div class="article-wrap reveal" style={`transition-delay:${Math.min(i,8)*0.05}s`} data-domain={(a.data as any).domain ?? ''}>
          <ArticleCard article={a} />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="no-results" class="no-results" hidden>
      <span>Aucun article dans cette catégorie.</span>
      <button class="btn btn-ghost" id="reset-filter" style="margin-top:1rem">Voir tous les articles</button>
    </div>
  </div>
</BaseLayout>

<style>
.page-hero {
  position: relative;
  overflow: hidden;
  padding: 7rem 0 4rem;
  border-bottom: 1px solid var(--border);
}
.hero-inner { text-align: center; position: relative; z-index: 1; }
.hero-inner h1 { font-size: clamp(2.2rem, 5vw, 4rem); line-height: 1.15; margin: 1rem 0; }
.hero-sub { color: var(--text-3); font-size: 1.05rem; max-width: 520px; margin: 0 auto; }

.filters {
  display: flex;
  flex-wrap: wrap;
  gap: .5rem;
  margin-bottom: 2.5rem;
}
.filter-btn {
  font-family: var(--font-sans);
  font-size: .8rem;
  font-weight: 600;
  letter-spacing: .04em;
  padding: .4rem 1rem;
  border-radius: var(--r-full);
  border: 1px solid var(--border);
  background: var(--glass);
  color: var(--text-3);
  cursor: pointer;
  transition: all .2s;
}
.filter-btn:hover  { color: var(--text-1); border-color: var(--border-bright); }
.filter-btn.active { background: rgba(145,94,255,.12); border-color: rgba(145,94,255,.35); color: var(--violet-light); }

.articles-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}
.article-wrap.hidden { display: none; }

.no-results {
  text-align: center;
  padding: 4rem;
  color: var(--text-3);
  font-size: 1rem;
}

@media(max-width:1024px) { .articles-grid { grid-template-columns: repeat(2, 1fr); } }
@media(max-width:640px)  { .articles-grid { grid-template-columns: 1fr; } }
</style>

<script is:inline>
(function() {
  const btns  = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.article-wrap');
  const noRes = document.getElementById('no-results');
  const reset = document.getElementById('reset-filter');

  function filter(domain) {
    let visible = 0;
    cards.forEach(c => {
      const show = domain === 'all' || c.dataset.domain === domain;
      c.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    if (noRes) noRes.hidden = visible > 0;
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filter(btn.dataset.filter || 'all');
    });
  });

  reset?.addEventListener('click', () => {
    btns.forEach(b => b.classList.toggle('active', b.dataset.filter === 'all'));
    filter('all');
  });
})();
</script>
