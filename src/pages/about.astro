---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = await getCollection('articles');
const books    = await getCollection('books');
const works    = await getCollection('work');

// Couleurs alignées avec src/config/domains.ts :
//   gestion-projet → blue · developpement-web → green · developpement-commercial → orange
//   qualite-process → purple · formation → yellow
const TIMELINE = [
  { period: 'Avril 2021 – Présent',     role: 'Pilote de Production & Chef de Projet Maintenance FTTB', company: 'KEOS TELECOM',   domain: 'Gestion de projet', color: '#60a5fa', icon: '🚀' },
  { period: 'Juin 2020 – Février 2021', role: 'Développeur Front-End',                                  company: "ACTIV'PARTNERS", domain: 'Développement web', color: '#34d399', icon: '💻' },
  { period: 'Juin 2015 – Juin 2018',    role: 'Superviseur Développement Commercial',                  company: 'SFR',            domain: 'Développement commercial', color: '#fb923c', icon: '🤝' },
  { period: '2012 – Juin 2015',         role: 'Chargé de Qualité, Formation & Méthodes',                company: 'SFR',            domain: 'Qualité & process', color: '#a78bfa', icon: '✅' },
  { period: 'Juin 2009 – Juin 2012',    role: 'Chargé de Formation (Offshore & Accompagnement)',        company: 'SFR',            domain: 'Formation & pédagogie', color: '#fbbf24', icon: '🎓' },
];

const TESTIMONIALS = [
  {
    quote: "Gérald a pris en charge la coordination de nos équipes terrain sur un projet de migration FTTB particulièrement tendu. Sa capacité à anticiper les blocages et à maintenir une communication fluide avec les sous-traitants nous a permis d'atteindre nos objectifs de délai malgré les imprévus. Un chef de projet dont on sait qu'il ne lâchera pas le fil.",
    name: "Marc Chevallier",
    role: "Directeur des Opérations Réseau",
    company: "KEOS TELECOM",
    avatar: "MC",
  },
  {
    quote: "Gérald a livré notre refonte front-end en React avec une rigueur que je n'avais pas souvent vue côté agence. Le temps de chargement a été divisé par deux, et le code est resté maintenable bien après sa mission. Il sait aussi expliquer ses choix techniques à des interlocuteurs non-développeurs, ce qui est précieux.",
    name: "Sophie Leroux",
    role: "Responsable Produit Digital",
    company: "ACTIV PARTNERS",
    avatar: "SL",
  },
  {
    quote: "En deux ans sous la direction de Gérald, notre équipe commerciale a atteint des résultats qu'on n'espérait plus. Ce n'est pas un manager qui donne des ordres — il donne du sens. Les entretiens de coaching mensuels étaient concrets, individualisés, et on sentait vraiment qu'il investissait dans nos progressions.",
    name: "Karim Bensalem",
    role: "Chargé de clientèle",
    company: "SFR",
    avatar: "KB",
  },
  {
    quote: "La formation que Gérald a animée sur les méthodes qualité était l'une des rares où l'on ressort avec des outils directement applicables le lendemain matin. Il adapte le niveau, pose les bonnes questions et sait rendre concret ce qui semblait abstrait. Un pédagogue authentique.",
    name: "Isabelle Fontaine",
    role: "Chargée de mission RH",
    company: "SFR",
    avatar: "IF",
  },
];

const VALS = [
  { icon: '🎯', title: 'Excellence opérationnelle', desc: 'Chaque projet mérite une exécution rigoureuse, des indicateurs clairs et une livraison dans les délais.' },
  { icon: '🤝', title: 'Collaboration authentique',  desc: 'Les meilleurs résultats naissent de la confiance, de la transparence et de l\'intelligence collective.' },
  { icon: '📈', title: 'Amélioration continue',      desc: 'Ne jamais se satisfaire du statu quo — chaque process peut être optimisé, chaque équipe peut progresser.' },
  { icon: '💡', title: 'Curiosité permanente',       desc: 'La tech, le management et la pédagogie évoluent vite. Rester à la pointe est une responsabilité professionnelle.' },
];
---

<BaseLayout title="À propos" description="Gérald Paméole — Chef de projet Pilotage d'Activité, expert en digitalisation et développeur web avec 20 ans d'expérience.">

  <!-- Hero -->
  <div class="about-hero">
    <div class="orb orb-violet" style="width:500px;height:500px;top:-150px;right:-100px;opacity:0.28;"></div>
    <div class="orb orb-cyan"   style="width:300px;height:300px;bottom:-80px;left:-60px;opacity:0.2;"></div>
    <div class="container">
      <div class="hero-grid">
        <!-- Text -->
        <div class="hero-text">
          <span class="section-label reveal">À propos</span>
          <h1 class="reveal reveal-delay-1" style="margin-top:1rem">
            Bonjour, je suis<br/><span class="gradient-text">Gérald Paméole</span>
          </h1>
          <p class="hero-tagline reveal reveal-delay-2">
            Chef de projet Pilotage d'Activité · Expert en digitalisation · Développeur web · Qualité &amp; méthodes · Formateur · Relation client premium
          </p>
          <p class="reveal reveal-delay-3" style="color:var(--text-3);font-size:1.05rem;line-height:1.85;max-width:560px">
            <strong style="color:var(--text-1)">Vingt ans. Six métiers. Une signature.</strong><br/>
            J'ai démarré sur le terrain de la relation client premium chez SFR, fait grimper des objectifs commerciaux,
            structuré des méthodes qualité, formé des centaines de collaborateurs, bâti des plateformes React,
            piloté des infrastructures télécoms critiques — toujours avec la même obsession : faire dialoguer
            les mondes que tout sépare.<br/><br/>
            Relation client, développement commercial, qualité-méthodes, ingénierie pédagogique, dev web, pilotage d'activité :
            ma force, c'est de naviguer entre eux pour traduire la complexité en livrables qui tiennent.
          </p>
          <div class="hero-ctas reveal reveal-delay-4">
            <a href="/contact" class="btn btn-primary">Me contacter</a>
            <a href="/metiers" class="btn btn-secondary">Voir mes métiers</a>
          </div>
        </div>

        <!-- Stats panel -->
        <div class="hero-stats-panel reveal reveal-delay-2">
          <div class="stat-item">
            <span class="stat-num gradient-text">20+</span>
            <span class="stat-txt">années d'expérience</span>
          </div>
          <div class="stat-item">
            <span class="stat-num gradient-text">{articles.length}</span>
            <span class="stat-txt">articles publiés</span>
          </div>
          <div class="stat-item">
            <span class="stat-num gradient-text">200+</span>
            <span class="stat-txt">professionnels formés</span>
          </div>
          <div class="stat-item">
            <span class="stat-num gradient-text">{works.length}</span>
            <span class="stat-txt">expériences clés</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Parcours -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label reveal">Parcours</span>
        <h2 class="reveal reveal-delay-1">Mon <span class="gradient-text">parcours</span></h2>
      </div>
      <div class="timeline">
        {TIMELINE.map((t, i) => (
          <div class="timeline-item reveal" style={`transition-delay:${i*0.1}s`}>
            <div class="timeline-icon" style={`background:${t.color}18;border-color:${t.color}40`}>{t.icon}</div>
            <div class="timeline-line" style={`background:${t.color}30`}></div>
            <div class="timeline-content glass-card">
              <span class="timeline-period" style={`color:${t.color}`}>{t.period}</span>
              <h3 class="timeline-role">{t.role}</h3>
              <p class="timeline-company">{t.company}</p>
              <span class="timeline-domain" style={`color:${t.color};background:${t.color}14;border-color:${t.color}33`}>{t.domain}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="divider-glow container"></div>

  <!-- Témoignages -->
  <section class="section" id="temoignages">
    <div class="container">
      <div class="section-header">
        <span class="section-label reveal">Témoignages</span>
        <h2 class="reveal reveal-delay-1">Ce qu'ils <span class="gradient-text">en disent</span></h2>
      </div>
      <div class="testimonials-grid">
        {TESTIMONIALS.map((t, i) => (
          <div class="testimonial-card glass-card reveal" style={`transition-delay:${i*0.1}s`}>
            <div class="testimonial-quote-mark">"</div>
            <p class="testimonial-text">{t.quote}</p>
            <div class="testimonial-author">
              <div class="testimonial-avatar" aria-hidden="true">{t.avatar}</div>
              <div class="testimonial-meta">
                <span class="testimonial-name">{t.name}</span>
                <span class="testimonial-role">{t.role} · {t.company}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="divider-glow container"></div>

  <!-- Valeurs -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label reveal">Valeurs</span>
        <h2 class="reveal reveal-delay-1">Ce qui guide <span class="gradient-text">mon travail</span></h2>
      </div>
      <div class="vals-grid">
        {VALS.map((v, i) => (
          <div class="val-card glass-card reveal" style={`transition-delay:${i*0.1}s`}>
            <span class="val-icon">{v.icon}</span>
            <h3 class="val-title">{v.title}</h3>
            <p class="val-desc">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="divider-glow container"></div>

  <!-- CTA contact -->
  <section class="section" style="padding-bottom:7rem">
    <div class="container container-sm">
      <div class="contact-cta glass-card reveal" style="text-align:center;padding:4rem 3rem">
        <span class="section-label" style="display:inline-block;margin-bottom:1.5rem">Contact</span>
        <h2 style="font-size:clamp(1.6rem,3vw,2.4rem);margin-bottom:1rem">
          Vous avez un projet ?<br/><span class="gradient-text">Parlons-en.</span>
        </h2>
        <p style="color:var(--text-3);max-width:420px;margin:0 auto 2rem;line-height:1.8">
          Que ce soit pour un projet de transformation, de formation ou de développement,
          je réponds sous 24h.
        </p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
          <a href="/contact" class="btn btn-primary">Envoyer un message</a>
          <a href="https://www.linkedin.com/in/geraldpameole/" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">LinkedIn</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.about-hero {
  position: relative;
  overflow: hidden;
  padding: 7rem 0 5rem;
  border-bottom: 1px solid var(--border);
}
.hero-grid {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4rem;
  align-items: center;
  position: relative;
  z-index: 1;
}
.hero-tagline {
  font-family: var(--font-mono);
  font-size: .85rem;
  color: var(--violet-light);
  letter-spacing: .06em;
  margin: .75rem 0 1.25rem;
}
.hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }

.hero-stats-panel {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: var(--r-xl);
  overflow: hidden;
  min-width: 300px;
}
.stat-item {
  background: var(--bg-1);
  padding: 1.75rem;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: .4rem;
}
.stat-num { font-family: var(--font-sans); font-size: 2.2rem; font-weight: 800; line-height: 1; }
.stat-txt  { font-size: .78rem; color: var(--text-3); letter-spacing: .04em; }

/* Timeline */
.timeline { display: flex; flex-direction: column; gap: 0; }
.timeline-item {
  display: grid;
  grid-template-columns: 56px 24px 1fr;
  gap: 0 1.25rem;
  align-items: flex-start;
}
.timeline-icon {
  width: 56px; height: 56px;
  border-radius: var(--r-lg);
  border: 1px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  flex-shrink: 0;
  margin-top: .25rem;
}
.timeline-line {
  width: 2px;
  align-self: stretch;
  margin: 0 auto;
  min-height: 60px;
}
.timeline-content {
  padding: 1.25rem 1.5rem;
  margin-bottom: 1rem;
}
.timeline-period  { font-family: var(--font-mono); font-size: .78rem; font-weight: 700; }
.timeline-role    { font-size: 1rem; font-weight: 700; color: var(--text-1); font-family: var(--font-sans); margin: .35rem 0 .2rem; }
.timeline-company { font-size: .855rem; color: var(--text-3); }
.timeline-domain  {
  display: inline-block;
  margin-top: .65rem;
  padding: .2rem .65rem;
  font-family: var(--font-mono);
  font-size: .72rem;
  font-weight: 600;
  letter-spacing: .02em;
  border: 1px solid;
  border-radius: var(--r-full);
}

/* Values */
.vals-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
.val-card { padding: 2rem; display: flex; flex-direction: column; gap: .75rem; }
.val-icon  { font-size: 1.8rem; }
.val-title { font-size: 1rem; font-weight: 700; color: var(--text-1); font-family: var(--font-sans); }
.val-desc  { font-size: .875rem; color: var(--text-3); line-height: 1.7; }

/* Testimonials */
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}
.testimonial-card {
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  position: relative;
}
.testimonial-quote-mark {
  font-family: Georgia, serif;
  font-size: 4rem;
  line-height: 1;
  color: var(--violet);
  opacity: 0.6;
  margin-bottom: -.75rem;
  user-select: none;
}
.testimonial-text {
  font-size: .9rem;
  color: var(--text-2);
  line-height: 1.8;
  flex: 1;
}
.testimonial-author {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
}
.testimonial-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(145, 94, 255, 0.15);
  border: 1px solid rgba(145, 94, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .75rem;
  font-weight: 700;
  font-family: var(--font-mono);
  color: var(--violet-light);
  flex-shrink: 0;
  letter-spacing: .04em;
}
.testimonial-meta {
  display: flex;
  flex-direction: column;
  gap: .2rem;
}
.testimonial-name {
  font-size: .9rem;
  font-weight: 700;
  color: var(--text-1);
  font-family: var(--font-sans);
}
.testimonial-role {
  font-size: .78rem;
  color: var(--text-3);
}

@media(max-width:900px) {
  .hero-grid { grid-template-columns: 1fr; }
  .hero-stats-panel { max-width: 400px; }
}
@media(max-width:640px) {
  .vals-grid { grid-template-columns: 1fr; }
  .testimonials-grid { grid-template-columns: 1fr; }
  .hero-stats-panel { grid-template-columns: repeat(2, 1fr); }
  .timeline-item { grid-template-columns: 44px 16px 1fr; }
}
</style>
