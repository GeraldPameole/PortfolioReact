---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const books = await getCollection('books');
const sorted = books.sort((a, b) => (b.data.note ?? 0) - (a.data.note ?? 0));

// Category mapping based on profession field
const CAT_MAP: Record<string, string> = {
  'developpement-web':        'Tech & Dev',
  'developpement-personnel':  'Croissance personnelle',
  'business':                 'Business & Stratégie',
  'management':               'Leadership',
};
const CATS = ['Tous', ...new Set(sorted.map(b => CAT_MAP[b.data.profession] ?? 'Autre'))];

const ACCENT: Record<string, string> = {
  'Tech & Dev':           '#67e8f9',
  'Croissance personnelle':'#86efac',
  'Business & Stratégie': '#fdba74',
  'Leadership':           '#c4b5fd',
  'Autre':                '#94a3b8',
};

function stars(n: number) {
  const full = Math.floor(n);
  const half = n % 1 >= 0.5;
  return { full, half, empty: 5 - full - (half ? 1 : 0) };
}
---

<BaseLayout title="Livres" description="Ma bibliothèque — les livres qui ont façonné ma vision du management, de la tech et du développement personnel.">

  <!-- Hero -->
  <div class="page-hero">
    <div class="orb orb-violet" style="width:500px;height:500px;top:-150px;right:-100px;opacity:0.28;"></div>
    <div class="orb orb-orange" style="width:300px;height:300px;bottom:-60px;left:-60px;opacity:0.2;"></div>
    <div class="container">
      <div class="hero-inner reveal">
        <span class="section-label">Bibliothèque</span>
        <h1 style="margin-top:1rem">
          {sorted.length} livres qui<br/><span class="gradient-text-warm">ont changé</span> ma façon de penser
        </h1>
        <p style="color:var(--text-3);font-size:1.05rem;max-width:520px;margin:1.25rem auto 0;line-height:1.8">
          Du management à la tech, du développement personnel au business — les ouvrages qui m'ont le plus marqué, avec mes notes et pourquoi ils comptent.
        </p>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <!-- Category filter -->
      <div class="cat-filters reveal">
        {CATS.map(cat => (
          <button class={`cat-btn ${cat === 'Tous' ? 'active' : ''}`} data-cat={cat}>{cat}</button>
        ))}
      </div>

      <!-- Books grid -->
      <div class="books-grid" id="books-grid">
        {sorted.map((book, i) => {
          const cat   = CAT_MAP[book.data.profession] ?? 'Autre';
          const color = ACCENT[cat] ?? '#94a3b8';
          const note  = book.data.note ?? 4;
          const s     = stars(note);

          return (
            <a href={`/livres/${book.slug}`} class="book-card reveal" style={`transition-delay:${Math.min(i,6)*0.07}s`} data-cat={cat}>
              <!-- Cover -->
              <div class="book-cover" style={`border-color:${color}30`}>
                {book.data.coverImage ? (
                  <img src={book.data.coverImage} alt={book.data.title} loading="lazy" />
                ) : (
                  <div class="book-cover-placeholder" style={`background:linear-gradient(135deg,${color}20,${color}08)`}>
                    <span class="cover-initial" style={`color:${color}`}>{book.data.title[0]}</span>
                  </div>
                )}
                <div class="cover-shine"></div>
              </div>

              <!-- Info -->
              <div class="book-info">
                <div class="book-meta">
                  <span class="book-cat" style={`color:${color};background:${color}15;border-color:${color}30`}>{cat}</span>
                  <span class="book-year">{book.data.publishYear}</span>
                </div>
                <h3 class="book-title">{book.data.title}</h3>
                <p class="book-author">{book.data.author}</p>

                <!-- Stars -->
                <div class="book-stars" aria-label={`Note: ${note}/5`}>
                  {Array.from({ length: s.full  }).map(() => <span class="star full"  style={`color:${color}`}>★</span>)}
                  {s.half                              &&     <span class="star half"  style={`color:${color}`}>★</span>}
                  {Array.from({ length: s.empty }).map(() => <span class="star empty"             >☆</span>)}
                  <span class="note-num" style={`color:${color}`}>{note}/5</span>
                </div>

                <p class="book-desc">{book.data.description}</p>

                <div class="book-link" style={`color:${color}`}>
                  Lire la fiche →
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <div id="no-books" class="no-results" hidden>
        <p>Aucun livre dans cette catégorie.</p>
        <button class="btn btn-ghost" id="reset-cat" style="margin-top:1rem">Voir tous les livres</button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-top:0;padding-bottom:6rem">
    <div class="container">
      <div class="reading-cta reveal">
        <span class="section-label">À propos</span>
        <h2 style="margin:.75rem 0">Pourquoi ces livres ?</h2>
        <p>
          Chaque ouvrage listé ici a eu un impact concret sur ma pratique professionnelle —
          une méthode adoptée, un projet transformé, une vision clarifiée.
          Je les recommande à tous ceux qui veulent progresser en management, en tech ou en développement personnel.
        </p>
        <a href="/contact" class="btn btn-primary" style="margin-top:1.75rem">Échangeons sur vos lectures →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-hero {
  position: relative;
  overflow: hidden;
  padding: 7rem 0 4.5rem;
  border-bottom: 1px solid var(--border);
}
.hero-inner { text-align: center; position: relative; z-index: 1; }
.hero-inner h1 { font-size: clamp(2rem, 5vw, 3.8rem); line-height: 1.15; }

.cat-filters {
  display: flex;
  flex-wrap: wrap;
  gap: .5rem;
  margin-bottom: 2.5rem;
}
.cat-btn {
  font-family: var(--font-sans);
  font-size: .82rem;
  font-weight: 600;
  padding: .45rem 1.15rem;
  border-radius: var(--r-full);
  border: 1px solid var(--border);
  background: var(--glass);
  color: var(--text-3);
  cursor: pointer;
  transition: all .2s;
  letter-spacing: .02em;
}
.cat-btn:hover  { color: var(--text-1); border-color: var(--border-bright); }
.cat-btn.active { background: rgba(145,94,255,.12); border-color: rgba(145,94,255,.35); color: var(--violet-light); }

.books-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.5rem;
}
.book-card {
  display: flex;
  gap: 1.5rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 1.5rem;
  text-decoration: none;
  transition: all .25s var(--ease-out);
  align-items: flex-start;
}
.book-card:hover {
  background: var(--bg-card-hover);
  border-color: var(--border-bright);
  transform: translateY(-3px);
  box-shadow: var(--shadow-md);
}
.book-card.hidden { display: none; }

.book-cover {
  width: 80px;
  min-width: 80px;
  height: 110px;
  border-radius: var(--r-md);
  overflow: hidden;
  border: 1px solid;
  position: relative;
  flex-shrink: 0;
}
.book-cover img { width: 100%; height: 100%; object-fit: cover; }
.book-cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-initial {
  font-family: var(--font-sans);
  font-size: 2rem;
  font-weight: 700;
}
.cover-shine {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 50%);
  pointer-events: none;
}

.book-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: .5rem; }
.book-meta  { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
.book-cat {
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: .18rem .6rem;
  border-radius: var(--r-full);
  border: 1px solid;
  font-family: var(--font-sans);
}
.book-year  { font-size: .75rem; color: var(--text-4); font-family: var(--font-mono); }
.book-title { font-size: 1rem; font-weight: 700; color: var(--text-1); font-family: var(--font-sans); line-height: 1.3; }
.book-author { font-size: .82rem; color: var(--text-3); font-style: italic; }
.book-stars { display: flex; align-items: center; gap: .15rem; }
.star { font-size: .95rem; }
.star.empty { color: var(--text-4); }
.star.half  { opacity: .65; }
.note-num   { font-family: var(--font-mono); font-size: .72rem; font-weight: 700; margin-left: .35rem; }
.book-desc  { font-size: .83rem; color: var(--text-3); line-height: 1.65; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.book-link  { font-size: .82rem; font-weight: 600; font-family: var(--font-mono); margin-top: auto; transition: opacity .2s; }
.book-card:hover .book-link { opacity: .75; }

.no-results { text-align: center; padding: 4rem; color: var(--text-3); }

.reading-cta {
  background: var(--bg-1);
  border: 1px solid var(--border);
  border-radius: var(--r-xl);
  padding: 3.5rem;
  text-align: center;
  max-width: 700px;
  margin: 0 auto;
}
.reading-cta h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); }
.reading-cta p  { color: var(--text-3); font-size: 1rem; line-height: 1.8; max-width: 520px; margin: 0 auto; }

@media(max-width:640px) {
  .books-grid { grid-template-columns: 1fr; }
  .book-cover { width: 65px; min-width: 65px; height: 90px; }
}
</style>

<script is:inline>
(function(){
  const btns  = document.querySelectorAll('.cat-btn');
  const cards = document.querySelectorAll('.book-card');
  const noRes = document.getElementById('no-books');
  const reset = document.getElementById('reset-cat');

  function filter(cat) {
    let visible = 0;
    cards.forEach(c => {
      const show = cat === 'Tous' || c.dataset.cat === cat;
      c.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    if (noRes) noRes.hidden = visible > 0;
  }

  btns.forEach(b => b.addEventListener('click', () => {
    btns.forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    filter(b.dataset.cat || 'Tous');
  }));
  reset?.addEventListener('click', () => {
    btns.forEach(b => b.classList.toggle('active', b.dataset.cat === 'Tous'));
    filter('Tous');
  });
})();
</script>
