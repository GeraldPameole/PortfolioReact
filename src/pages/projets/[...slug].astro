---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackToTop from '../../components/BackToTop.astro';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  return entries.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, img, img_alt, company, period, location, technologies, tags, publishDate } = entry.data;

const date = publishDate
  ? new Date(publishDate).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' })
  : null;
---

<BaseLayout title={title} description={description ?? title}>

  <!-- Hero -->
  <div class="project-hero">
    <div class="orb orb-violet" style="width:400px;height:400px;top:-100px;right:-80px;opacity:0.25;"></div>

    {img && (
      <div class="hero-image-wrap">
        <img src={img} alt={img_alt ?? title} class="hero-image" fetchpriority="high" decoding="async" />
        <div class="hero-image-overlay"></div>
      </div>
    )}

    <div class="container hero-content">
      <a href="/projets" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
        Retour aux projets
      </a>

      <div class="hero-meta">
        {company && <span class="hero-company">{company}</span>}
        {date && <span class="hero-date">{date}</span>}
      </div>
      <h1 class="hero-title">{title}</h1>
      {description && <p class="hero-desc">{description}</p>}

      <div class="hero-badges">
        {period   && <span class="hero-badge"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>{period}</span>}
        {location && <span class="hero-badge"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>{location}</span>}
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="project-body">
    <div class="container">
      <div class="project-layout">

        <!-- Main content -->
        <article class="project-article prose">
          <Content />
        </article>

        <!-- Sidebar -->
        <aside class="project-sidebar">

          {technologies && technologies.length > 0 && (
            <div class="sidebar-block">
              <h2 class="sidebar-title">Technologies & méthodes</h2>
              <div class="tech-grid">
                {technologies.map((t: string) => <span class="tech-pill">{t}</span>)}
              </div>
            </div>
          )}

          {tags && tags.length > 0 && (
            <div class="sidebar-block">
              <h3 class="sidebar-title">Tags</h3>
              <div class="tags-list">
                {tags.map((tag: string) => <span class="tag-pill">{tag}</span>)}
              </div>
            </div>
          )}

          <div class="sidebar-block">
            <h3 class="sidebar-title">Intéressé par ce type de projet ?</h3>
            <p style="font-size:.875rem;color:var(--text-3);line-height:1.7;margin-bottom:1.25rem">
              Vous avez un projet similaire ou souhaitez discuter de votre contexte ?
            </p>
            <a href="/contact" class="btn btn-primary" style="width:100%;justify-content:center">
              Contactez-moi →
            </a>
          </div>

          <a href="/projets" class="back-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
            Tous les projets
          </a>
        </aside>
      </div>
    </div>
  </div>

  <BackToTop />
</BaseLayout>

<style>
/* Hero */
.project-hero {
  position: relative;
  overflow: hidden;
  min-height: 340px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  border-bottom: 1px solid var(--border);
}
.hero-image-wrap {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.25;
  filter: saturate(0.6);
}
.hero-image-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, var(--bg-0) 30%, rgba(5,8,22,0.7) 100%);
}
.hero-content {
  position: relative;
  z-index: 1;
  padding-top: 7rem;
  padding-bottom: 3.5rem;
}
.back-link {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  color: var(--text-3);
  font-size: .875rem;
  text-decoration: none;
  margin-bottom: 2rem;
  transition: color .2s;
  font-family: var(--font-mono);
}
.back-link:hover { color: var(--text-1); }
.hero-meta { display: flex; align-items: center; gap: 1rem; margin-bottom: .75rem; flex-wrap: wrap; }
.hero-company { font-family: var(--font-mono); font-size: .8rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--violet-light); }
.hero-date    { font-family: var(--font-mono); font-size: .78rem; color: var(--text-3); }
.hero-title   { font-size: clamp(1.8rem, 4vw, 3.2rem); color: var(--text-1); margin-bottom: 1rem; line-height: 1.15; }
.hero-desc    { font-size: 1.05rem; color: var(--text-3); max-width: 640px; line-height: 1.8; margin-bottom: 1.5rem; }
.hero-badges  { display: flex; flex-wrap: wrap; gap: .6rem; }
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  font-family: var(--font-mono);
  font-size: .78rem;
  color: var(--text-3);
  background: var(--glass);
  border: 1px solid var(--border);
  border-radius: var(--r-full);
  padding: .3rem .85rem;
}

/* Body layout */
.project-body { padding: 3rem 0 6rem; }
.project-layout {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 4rem;
  align-items: flex-start;
}

/* Article prose */
.project-article {
  min-width: 0;
}
.project-article :global(h1) { display: none; } /* title already in hero */
.project-article :global(h2) {
  font-size: 1.4rem;
  color: var(--text-1);
  margin: 2.5rem 0 .75rem;
  padding-bottom: .5rem;
  border-bottom: 1px solid var(--border);
  font-family: var(--font-sans);
}
.project-article :global(h3) {
  font-size: 1.1rem;
  color: var(--violet-light);
  margin: 2rem 0 .6rem;
  font-family: var(--font-sans);
}
.project-article :global(h4) { color: var(--text-2); margin: 1.5rem 0 .4rem; }
.project-article :global(p)  { color: var(--text-2); line-height: 1.85; margin-bottom: 1.1rem; }
.project-article :global(ul),
.project-article :global(ol) { color: var(--text-2); margin-bottom: 1.1rem; padding-left: 1.5rem; }
.project-article :global(li) { margin-bottom: .5rem; line-height: 1.7; }
.project-article :global(strong) { color: var(--text-1); font-weight: 600; }
.project-article :global(em) { color: var(--violet-light); }
.project-article :global(blockquote) {
  border-left: 3px solid var(--violet);
  padding: .75rem 1.5rem;
  margin: 1.5rem 0;
  background: rgba(145,94,255,0.06);
  border-radius: 0 var(--r-md) var(--r-md) 0;
  color: var(--text-3);
}
.project-article :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin: 1.5rem 0;
  font-size: .9rem;
}
.project-article :global(th) {
  background: var(--bg-2);
  color: var(--text-1);
  padding: .75rem 1rem;
  text-align: left;
  font-family: var(--font-sans);
  font-weight: 700;
  border-bottom: 1px solid var(--border-bright);
}
.project-article :global(td) {
  padding: .75rem 1rem;
  border-bottom: 1px solid var(--border);
  color: var(--text-2);
}
.project-article :global(tr:last-child td) { border-bottom: none; }
.project-article :global(code) {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  padding: .15em .5em;
  font-size: .875em;
  color: var(--cyan);
}
.project-article :global(.metric) {
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  background: rgba(145,94,255,0.1);
  border: 1px solid rgba(145,94,255,0.25);
  border-radius: var(--r-full);
  padding: .25rem .85rem;
  font-family: var(--font-mono);
  font-size: .8rem;
  color: var(--violet-light);
  margin: .15rem;
}

/* Sidebar */
.project-sidebar { position: sticky; top: 6rem; display: flex; flex-direction: column; gap: 1.5rem; }
.sidebar-block {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 1.5rem;
}
.sidebar-title {
  font-family: var(--font-sans);
  font-size: .78rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 1rem;
}
.tech-grid { display: flex; flex-wrap: wrap; gap: .4rem; }
.tech-pill {
  font-family: var(--font-mono);
  font-size: .75rem;
  padding: .3rem .75rem;
  background: var(--glass);
  border: 1px solid var(--border);
  border-radius: var(--r-full);
  color: var(--cyan-light);
  transition: all .2s;
}
.tech-pill:hover { border-color: var(--cyan); }
.tags-list { display: flex; flex-wrap: wrap; gap: .4rem; }
.tag-pill {
  font-size: .72rem;
  padding: .22rem .65rem;
  background: rgba(145,94,255,0.08);
  border: 1px solid rgba(145,94,255,0.2);
  border-radius: var(--r-full);
  color: var(--violet-light);
  font-family: var(--font-sans);
  font-weight: 600;
}
.back-btn {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  color: var(--text-3);
  font-size: .875rem;
  text-decoration: none;
  transition: color .2s;
  font-family: var(--font-mono);
}
.back-btn:hover { color: var(--text-1); }

@media(max-width:900px) {
  .project-layout { grid-template-columns: 1fr; }
  .project-sidebar { position: static; order: -1; flex-direction: row; flex-wrap: wrap; }
  .sidebar-block   { flex: 1; min-width: 250px; }
}
</style>
