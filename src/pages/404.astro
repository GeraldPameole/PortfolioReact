---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const recent = articles
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3);
---

<BaseLayout title="Page introuvable" description="Cette page n'existe pas — retournez à l'accueil ou explorez le blog.">

  <section class="error-page">
    <div class="orb orb-violet" style="width:500px;height:500px;top:-150px;right:-100px;opacity:0.18;"></div>
    <div class="orb orb-cyan"   style="width:350px;height:350px;bottom:-80px;left:-80px;opacity:0.14;"></div>

    <div class="container">
      <div class="error-inner">

        <!-- Code 404 animé -->
        <div class="error-code" aria-hidden="true">404</div>

        <span class="section-label">Page introuvable</span>
        <h1 class="error-title">
          Cette page n'existe <span class="gradient-text">plus</span>
        </h1>
        <p class="error-desc">
          Elle a peut-être été déplacée, renommée ou supprimée.<br/>
          Voici où aller depuis ici :
        </p>

        <!-- Navigation rapide -->
        <nav class="error-nav">
          <a href="/" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Accueil
          </a>
          <a href="/blog" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Blog
          </a>
          <a href="/about" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            À propos
          </a>
          <a href="/contact" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Contact
          </a>
        </nav>

        <!-- Articles récents -->
        {recent.length > 0 && (
          <div class="recent-articles">
            <p class="recent-label">Articles récents</p>
            <ul class="recent-list">
              {recent.map(a => (
                <li>
                  <a href={`/blog/${a.id.replace(/.md$/, '')}`} class="recent-link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--violet-light)" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    {a.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

      </div>
    </div>
  </section>

</BaseLayout>

<style>
.error-page {
  min-height: calc(100vh - 80px);
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding: 5rem 0;
}

.error-inner {
  max-width: 560px;
  margin: 0 auto;
  text-align: center;
  position: relative;
  z-index: 1;
}

.error-code {
  font-size: clamp(7rem, 18vw, 11rem);
  font-weight: 900;
  font-family: var(--font-mono);
  line-height: 1;
  background: linear-gradient(135deg, var(--violet) 0%, var(--cyan) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  opacity: 0.18;
  user-select: none;
  letter-spacing: -0.04em;
  margin-bottom: -1.5rem;
}

.section-label {
  display: inline-block;
  margin-bottom: 1rem;
}

.error-title {
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  font-weight: 800;
  color: var(--text-1);
  margin: 0.75rem 0 1.25rem;
  line-height: 1.2;
}

.error-desc {
  color: var(--text-3);
  font-size: 1rem;
  line-height: 1.8;
  margin-bottom: 2.5rem;
}

.error-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: center;
  margin-bottom: 3rem;
}

.btn-outline {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.65rem 1.25rem;
  border: 1px solid var(--border-bright);
  border-radius: var(--r-full);
  color: var(--text-2);
  font-size: 0.875rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.2s;
  background: var(--glass);
}
.btn-outline:hover {
  color: var(--text-1);
  border-color: var(--violet-light);
  background: rgba(145, 94, 255, 0.08);
}

.btn.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.recent-articles {
  border-top: 1px solid var(--border);
  padding-top: 2rem;
  text-align: left;
  max-width: 420px;
  margin: 0 auto;
}

.recent-label {
  font-size: 0.75rem;
  font-family: var(--font-mono);
  color: var(--text-4);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 1rem;
}

.recent-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
}

.recent-link {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--text-2);
  text-decoration: none;
  font-size: 0.875rem;
  line-height: 1.5;
  transition: color 0.2s;
}
.recent-link:hover { color: var(--text-1); }
</style>
