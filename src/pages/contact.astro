---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Parlons de votre projet — transformation digitale, gestion de projet télécom, développement web ou formation. Réponse sous 24h."
>

  <!-- Hero -->
  <div class="page-hero">
    <div class="orb orb-violet" style="width:450px;height:450px;top:-120px;right:-80px;opacity:0.25;"></div>
    <div class="orb orb-cyan"   style="width:300px;height:300px;bottom:-60px;left:-60px;opacity:0.2;"></div>
    <div class="container">
      <div style="text-align:center;position:relative;z-index:1">
        <span class="section-label reveal">Contact</span>
        <h1 class="reveal reveal-delay-1" style="margin-top:1rem">
          Parlons de votre <span class="gradient-text">projet</span>
        </h1>
        <p class="reveal reveal-delay-2" style="color:var(--text-3);font-size:1.05rem;max-width:520px;margin:1.25rem auto 0;line-height:1.8">
          Transformation digitale, gestion de projet télécom, développement web ou formation —
          décrivez votre contexte et je vous réponds sous 24h avec une proposition concrète.
        </p>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container contact-grid">

      <!-- ── Left: infos + FAQ ─────────────────────────────────────────── -->
      <div class="info-col">

        <!-- Coordonnées -->
        <div class="info-card glass-card reveal">
          <h2 class="info-title">Coordonnées</h2>

          <div class="info-item">
            <div class="info-icon" style="background:rgba(145,94,255,.12);border-color:rgba(145,94,255,.3)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--violet-light)" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <p class="info-label">Email</p>
              <a href="mailto:gerald.pameole@gmail.com" class="info-val">gerald.pameole@gmail.com</a>
              <p class="info-sub">Réponse sous 24h</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon" style="background:rgba(0,207,253,.1);border-color:rgba(0,207,253,.25)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--cyan)" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="info-label">Localisation</p>
              <p class="info-val">Paris, France</p>
              <p class="info-sub">Télétravail & déplacements possibles</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon" style="background:rgba(134,239,172,.1);border-color:rgba(134,239,172,.25)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#86efac" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="info-label">Disponibilité</p>
              <p class="info-val">Consultation gratuite — 30 min</p>
              <p class="info-sub">Lun–Ven · 9h–18h</p>
            </div>
          </div>

          <!-- Calendly RDV -->
          <div class="rdv-block">
            <div class="rdv-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--cyan)" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div>
              <p class="rdv-title">Consultation gratuite — 30 min</p>
              <p class="rdv-sub">Réservez directement un créneau sans attendre ma réponse.</p>
              <a
                href="https://calendly.com/gerald-pameole/30min"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-secondary rdv-btn"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Choisir un créneau →
              </a>
            </div>
          </div>

          <div class="socials">
            <a href="https://www.linkedin.com/in/geraldpameole/" target="_blank" rel="noopener noreferrer" class="social-pill">
              <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              LinkedIn
            </a>
            <a href="https://github.com/GeraldPameole" target="_blank" rel="noopener noreferrer" class="social-pill">
              <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          </div>
        </div>

        <!-- FAQ -->
        <div class="faq-block glass-card reveal reveal-delay-1">
          <h2 class="info-title">Questions fréquentes</h2>
          <div class="faq-list">
            <details class="faq-item">
              <summary>Quel est votre délai de réponse ?</summary>
              <p>Je réponds à toutes les demandes sous 24h ouvrées. Pour les urgences, précisez-le dans le formulaire.</p>
            </details>
            <details class="faq-item">
              <summary>Proposez-vous une consultation gratuite ?</summary>
              <p>Oui — 30 minutes d'échange pour cadrer votre besoin et valider si je peux vous aider concrètement.</p>
            </details>
            <details class="faq-item">
              <summary>Travaillez-vous à distance ?</summary>
              <p>Principalement. Je me déplace sur Paris et région parisienne selon le contexte du projet.</p>
            </details>
            <details class="faq-item">
              <summary>Quels types de missions prenez-vous ?</summary>
              <p>Gestion de projet télécom/IT, développement web front-end, formation professionnelle, conseil en transformation digitale. Freelance ou prestation ponctuelle.</p>
            </details>
          </div>
        </div>

      </div>

      <!-- ── Right: form ───────────────────────────────────────────────── -->
      <div class="form-col reveal reveal-delay-1">
        <div class="form-card glass-card">
          <h2 class="form-title">Décrivez votre projet</h2>
          <p class="form-subtitle">Plus votre contexte est précis, plus ma réponse sera utile.</p>

          <form id="contact-form" action="https://formspree.io/f/mpqewwgj" method="POST" class="form" novalidate>

            <!-- Nom + Prénom -->
            <div class="field-row">
              <div class="field">
                <label for="firstName">Prénom <span class="req">*</span></label>
                <input type="text" id="firstName" name="firstName" required placeholder="Votre prénom" autocomplete="given-name"/>
              </div>
              <div class="field">
                <label for="lastName">Nom <span class="req">*</span></label>
                <input type="text" id="lastName" name="lastName" required placeholder="Votre nom" autocomplete="family-name"/>
              </div>
            </div>

            <!-- Email -->
            <div class="field">
              <label for="email">Email professionnel <span class="req">*</span></label>
              <input type="email" id="email" name="email" required placeholder="vous@entreprise.com" autocomplete="email"/>
            </div>

            <!-- Entreprise + Poste -->
            <div class="field-row">
              <div class="field">
                <label for="company">Entreprise</label>
                <input type="text" id="company" name="company" placeholder="Nom de votre organisation" autocomplete="organization"/>
              </div>
              <div class="field">
                <label for="role">Votre rôle</label>
                <input type="text" id="role" name="role" placeholder="ex: Directeur IT, DRH…"/>
              </div>
            </div>

            <!-- Type de projet -->
            <div class="field">
              <label for="project-type">Type de projet <span class="req">*</span></label>
              <select id="project-type" name="project_type" required>
                <option value="">Sélectionnez…</option>
                <option value="gestion-projet-telecom">Gestion de projet télécom / IT</option>
                <option value="developpement-web">Développement web (site, application)</option>
                <option value="formation">Formation professionnelle / coaching</option>
                <option value="transformation-digitale">Conseil en transformation digitale</option>
                <option value="management-commercial">Management commercial / équipe</option>
                <option value="qualite-process">Qualité & optimisation des processus</option>
                <option value="autre">Autre / à définir</option>
              </select>
            </div>

            <!-- Budget + Délai -->
            <div class="field-row">
              <div class="field">
                <label for="budget">Budget indicatif</label>
                <select id="budget" name="budget">
                  <option value="">Non défini</option>
                  <option value="<5k">Moins de 5 000 €</option>
                  <option value="5k-15k">5 000 – 15 000 €</option>
                  <option value="15k-50k">15 000 – 50 000 €</option>
                  <option value=">50k">Plus de 50 000 €</option>
                  <option value="discussion">À discuter</option>
                </select>
              </div>
              <div class="field">
                <label for="urgency">Délai souhaité <span class="req">*</span></label>
                <select id="urgency" name="urgency" required>
                  <option value="">Sélectionnez…</option>
                  <option value="urgent">Urgent — sous 2 semaines</option>
                  <option value="court">Court terme — 1 à 3 mois</option>
                  <option value="moyen">Moyen terme — 3 à 6 mois</option>
                  <option value="long">Long terme — 6 mois+</option>
                  <option value="reflexion">En réflexion, pas de deadline</option>
                </select>
              </div>
            </div>

            <!-- Message -->
            <div class="field">
              <label for="message">Décrivez votre projet <span class="req">*</span></label>
              <textarea id="message" name="message" rows="5" required placeholder="Contexte, objectifs, contraintes particulières, ce que vous attendez de cette collaboration…"></textarea>
            </div>

            <!-- RGPD -->
            <div class="field-check">
              <input type="checkbox" id="privacy" name="privacy" required/>
              <label for="privacy">J'accepte que mes données soient utilisées pour traiter ma demande. <span class="req">*</span></label>
            </div>

            <button type="submit" class="btn btn-primary submit-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              Envoyer ma demande
            </button>
          </form>

          <div id="form-success" class="success-msg" hidden>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#86efac" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <div>
              <strong>Message envoyé !</strong>
              <p>Je vous réponds sous 24h avec une proposition adaptée à votre contexte.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.page-hero {
  position: relative;
  overflow: hidden;
  padding: 7rem 0 4.5rem;
  border-bottom: 1px solid var(--border);
}

.contact-grid {
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 2.5rem;
  align-items: flex-start;
}

/* ── Info column ── */
.info-col { display: flex; flex-direction: column; gap: 1.5rem; }
.info-card, .faq-block { padding: 2rem; }
.info-title {
  font-family: var(--font-sans);
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-1);
  margin-bottom: 1.5rem;
  letter-spacing: -.01em;
}
.info-item {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
  margin-bottom: 1.35rem;
}
.info-item:last-of-type { margin-bottom: 1.5rem; }
.info-icon {
  width: 38px; height: 38px; min-width: 38px;
  border-radius: var(--r-md);
  border: 1px solid;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.info-label { font-size: .72rem; color: var(--text-4); font-family: var(--font-mono); letter-spacing: .05em; text-transform: uppercase; margin-bottom: .2rem; }
.info-val   { font-size: .9rem; color: var(--text-1); font-weight: 600; text-decoration: none; transition: color .2s; }
a.info-val:hover { color: var(--violet-light); }
.info-sub   { font-size: .78rem; color: var(--text-3); margin-top: .15rem; }

.socials { display: flex; gap: .65rem; margin-top: .5rem; }
.social-pill {
  display: inline-flex; align-items: center; gap: .45rem;
  font-family: var(--font-mono); font-size: .78rem; font-weight: 600;
  color: var(--text-2); background: var(--glass);
  border: 1px solid var(--border); border-radius: var(--r-full);
  padding: .35rem .9rem; text-decoration: none;
  transition: all .2s;
}
.social-pill:hover { color: var(--text-1); border-color: var(--border-bright); }

/* ── FAQ ── */
.faq-list { display: flex; flex-direction: column; gap: .75rem; }
.faq-item {
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  overflow: hidden;
}
.faq-item summary {
  padding: .9rem 1.1rem;
  font-size: .88rem;
  font-weight: 600;
  color: var(--text-1);
  cursor: pointer;
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background .2s;
}
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::after {
  content: '+';
  font-size: 1.1rem;
  color: var(--violet-light);
  font-weight: 400;
  transition: transform .25s;
}
.faq-item[open] summary { background: rgba(145,94,255,.06); }
.faq-item[open] summary::after { content: '−'; }
.faq-item p { padding: .75rem 1.1rem 1rem; font-size: .85rem; color: var(--text-3); line-height: 1.75; }

/* ── Form ── */
.form-card { padding: 2.5rem; }
.form-title    { font-size: 1.2rem; font-weight: 700; color: var(--text-1); margin-bottom: .4rem; font-family: var(--font-sans); }
.form-subtitle { font-size: .875rem; color: var(--text-3); margin-bottom: 2rem; line-height: 1.6; }

.form { display: flex; flex-direction: column; gap: 1.1rem; }
.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.field { display: flex; flex-direction: column; gap: .45rem; }
.field label {
  font-size: .78rem;
  font-weight: 600;
  color: var(--text-2);
  font-family: var(--font-sans);
  letter-spacing: .03em;
}
.req { color: var(--violet-light); }

.field input,
.field select,
.field textarea {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: .7rem 1rem;
  font-size: .875rem;
  color: var(--text-1);
  font-family: var(--font-sans);
  transition: border-color .2s, box-shadow .2s;
  width: 100%;
}
.field input::placeholder,
.field textarea::placeholder { color: var(--text-4); }
.field input:focus,
.field select:focus,
.field textarea:focus {
  outline: none;
  border-color: var(--violet);
  box-shadow: 0 0 0 3px rgba(145,94,255,.12);
}
.field select { cursor: pointer; }
.field select option { background: var(--bg-1); color: var(--text-1); }
.field textarea { resize: vertical; min-height: 120px; line-height: 1.7; }

.field-check {
  display: flex;
  align-items: flex-start;
  gap: .65rem;
  margin-top: .25rem;
}
.field-check input[type="checkbox"] {
  width: 16px; min-width: 16px; height: 16px;
  margin-top: .15rem;
  accent-color: var(--violet);
  cursor: pointer;
}
.field-check label { font-size: .8rem; color: var(--text-3); line-height: 1.5; cursor: pointer; }

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .65rem;
  padding: .9rem 1.5rem;
  font-size: .95rem;
  margin-top: .5rem;
}

.rdv-block {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
  padding: 1.25rem;
  background: rgba(0,207,253,0.05);
  border: 1px solid rgba(0,207,253,0.2);
  border-radius: var(--r-lg);
  margin-bottom: 1.25rem;
}
.rdv-icon {
  width: 36px; height: 36px; min-width: 36px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(0,207,253,0.1); border: 1px solid rgba(0,207,253,0.25);
  border-radius: var(--r-md);
}
.rdv-title { font-size: .88rem; font-weight: 700; color: var(--text-1); margin-bottom: .2rem; }
.rdv-sub   { font-size: .8rem; color: var(--text-3); line-height: 1.55; margin-bottom: .75rem; }
.rdv-btn   { display: inline-flex; align-items: center; gap: .4rem; font-size: .82rem; padding: .45rem 1rem; }

.success-msg {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  background: rgba(134,239,172,.07);
  border: 1px solid rgba(134,239,172,.25);
  border-radius: var(--r-lg);
  margin-top: 1.5rem;
}
.success-msg svg { flex-shrink: 0; margin-top: .1rem; }
.success-msg strong { display: block; color: #86efac; font-size: .95rem; margin-bottom: .25rem; }
.success-msg p { font-size: .85rem; color: var(--text-3); margin: 0; line-height: 1.6; }

@media(max-width:900px) {
  .contact-grid { grid-template-columns: 1fr; }
  .info-col { order: 2; }
  .form-col { order: 1; }
}
@media(max-width:560px) {
  .field-row { grid-template-columns: 1fr; }
}
</style>

<script>
document.addEventListener('astro:page-load', () => {
  const form    = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  if (!form) return;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Envoi en cours…';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' },
      });
      if (res.ok) {
        form.style.display = 'none';
        if (success) success.hidden = false;
      } else {
        alert('Une erreur s\'est produite. Veuillez réessayer ou m\'écrire directement à gerald.pameole@gmail.com');
        btn.disabled = false;
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Envoyer ma demande';
      }
    } catch {
      alert('Erreur réseau. Écrivez-moi directement à gerald.pameole@gmail.com');
      btn.disabled = false;
    }
  });
});
</script>
