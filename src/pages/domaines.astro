---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { DOMAINS_CONFIG, getDomainConfig } from '../config/domains';

const allArticles = await getCollection('articles');

// Build domain → articles mapping
const domainsData = Object.entries(DOMAINS_CONFIG).map(([key, cfg]) => {
  const articles = allArticles
    .filter((a: any) => a.data.domain === key)
    .sort((a: any, b: any) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
    .slice(0, 4);
  return { key, cfg, articles, total: allArticles.filter((a: any) => a.data.domain === key).length };
}).filter(d => d.total > 0).sort((a, b) => b.total - a.total);

const ACCENT_COLORS: Record<string, string> = {
  blue: '#60a5fa', green: '#34d399', purple: '#a78bfa',
  yellow: '#fbbf24', orange: '#fb923c', indigo: '#818cf8',
  cyan: '#22d3ee', pink: '#f472b6', violet: '#a78bfa',
  teal: '#2dd4bf', emerald: '#34d399', sky: '#38bdf8',
  amber: '#fbbf24', slate: '#94a3b8', rose: '#fb7185',
};
---

<BaseLayout title="Domaines" description="15 domaines d'expertise couvrant la gestion de projet, le management, le digital et la formation.">

  <div class="page-hero">
    <div class="orb orb-cyan"   style="width:400px;height:400px;top:-100px;right:-80px;opacity:0.25;"></div>
    <div class="orb orb-violet" style="width:350px;height:350px;bottom:-50px;left:-80px;opacity:0.2;"></div>
    <div class="container">
      <div style="text-align:center;position:relative;z-index:1">
        <span class="section-label reveal">Expertise</span>
        <h1 class="reveal reveal-delay-1" style="margin-top:1rem">
          {domainsData.length} domaines<br/><span class="gradient-text">d'expertise</span>
        </h1>
        <p class="reveal reveal-delay-2" style="color:var(--text-3);font-size:1.05rem;max-width:500px;margin:1rem auto 0">
          {allArticles.length} articles répartis sur {domainsData.length} domaines de compétences.
        </p>
      </div>
    </div>
  </div>

  <div class="section container">
    <!-- Domain cards -->
    <div class="domains-list">
      {domainsData.map(({ key, cfg, articles, total }, i) => {
        const accent = ACCENT_COLORS[cfg.color] ?? 'var(--violet-light)';
        return (
          <div class="domain-block reveal" style={`transition-delay:${Math.min(i,5)*0.1}s`}>
            <!-- Domain header -->
            <div class="domain-header">
              <div class="domain-icon-wrap" style={`background:${accent}18;border-color:${accent}40`}>
                <span class="domain-emoji">{cfg.icon}</span>
              </div>
              <div class="domain-info">
                <h2 class="domain-title" style={`color:${accent}`}>{cfg.name}</h2>
                <p class="domain-desc">{cfg.description}</p>
                <div class="domain-meta">
                  <span class="meta-pill" style={`background:${accent}15;border-color:${accent}35;color:${accent}`}>
                    {total} article{total > 1 ? 's' : ''}
                  </span>
                  <span class="meta-impact">{cfg.impact}</span>
                </div>
              </div>
            </div>

            <!-- Technologies -->
            <div class="tech-row">
              {(cfg.technologies as readonly string[]).map((t: string) => (
                <span class="tech-badge" style={`border-color:${accent}30;color:${accent}`}>{t}</span>
              ))}
            </div>

            <!-- Latest articles -->
            {articles.length > 0 && (
              <div class="article-list">
                {articles.map((a: any) => (
                  <a href={`/blog/${a.slug}`} class="article-row">
                    <span class="article-dot" style={`background:${accent}`}></span>
                    <span class="article-title">{a.data.title}</span>
                    <span class="article-arrow" style={`color:${accent}`}>→</span>
                  </a>
                ))}
                {total > 4 && (
                  <a href={`/blog`} class="see-more" style={`color:${accent}`}>
                    +{total - 4} autres articles →
                  </a>
                )}
              </div>
            )}

            <div class="domain-divider" style={`background:linear-gradient(90deg,${accent}40,transparent)`}></div>
          </div>
        );
      })}
    </div>
  </div>

</BaseLayout>

<style>
.page-hero {
  position: relative;
  overflow: hidden;
  padding: 7rem 0 4rem;
  border-bottom: 1px solid var(--border);
}
.domains-list { display: flex; flex-direction: column; gap: 3.5rem; }

.domain-block { display: flex; flex-direction: column; gap: 1.25rem; }

.domain-header {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 1.5rem;
  align-items: flex-start;
}
.domain-icon-wrap {
  width: 60px; height: 60px;
  border-radius: var(--r-lg);
  border: 1px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.domain-emoji { font-size: 1.6rem; }
.domain-title { font-size: 1.3rem; font-weight: 700; font-family: var(--font-sans); margin-bottom: .4rem; }
.domain-desc  { font-size: .9rem; color: var(--text-3); line-height: 1.7; margin-bottom: .75rem; }
.domain-meta  { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; }
.meta-pill {
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: .2rem .65rem;
  border-radius: var(--r-full);
  border: 1px solid;
  font-family: var(--font-sans);
}
.meta-impact { font-size: .8rem; color: var(--text-4); font-family: var(--font-mono); }

.tech-row { display: flex; flex-wrap: wrap; gap: .4rem; }
.tech-badge {
  font-family: var(--font-mono);
  font-size: .73rem;
  padding: .22rem .65rem;
  border-radius: var(--r-full);
  border: 1px solid;
  background: transparent;
}

.article-list {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  overflow: hidden;
}
.article-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: .85rem 1.25rem;
  text-decoration: none;
  border-bottom: 1px solid var(--border);
  transition: background .2s;
}
.article-row:last-of-type  { border-bottom: none; }
.article-row:hover { background: var(--bg-card-hover); }
.article-dot   { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.article-title { font-size: .9rem; color: var(--text-2); flex: 1; transition: color .2s; }
.article-row:hover .article-title { color: var(--text-1); }
.article-arrow { font-size: .9rem; transition: transform .2s; }
.article-row:hover .article-arrow { transform: translateX(3px); }
.see-more {
  display: block;
  padding: .75rem 1.25rem;
  font-size: .82rem;
  font-family: var(--font-mono);
  text-decoration: none;
  font-weight: 600;
  transition: opacity .2s;
}
.see-more:hover { opacity: .75; }

.domain-divider { height: 1px; opacity: .3; margin-top: .5rem; }

@media(max-width:640px) {
  .domain-header { grid-template-columns: 1fr; }
  .domain-icon-wrap { display: none; }
}
</style>
